<layout type="Web">
	<view>
		<responsive name="PageContent" class="page">
			<row>
				<cell>
					<responsive name="HeaderBand" class="page-header">
						<row>
							<cell horizontalAlignment="Left" verticalAlignment="Middle">
								<table name="HeaderBrand" width="100%" class="header-brand" tableType="Flex" alignItems="Center">
									<row>
										<cell verticalAlignment="Middle" flexGrow="0">
											<label name="LblEscudoPortal" caption="A" class="header-crest" />
										</cell>
										<cell flexGrow="0">
											<responsive name="HeaderTextBlock">
												<row>
													<cell>
														<table name="HeaderNameRow" tableType="Flex" alignItems="Center">
															<row>
																<cell flexGrow="0">
																	<label name="LblBrandClub" caption="Club" class="header-name" />
																</cell>
																<cell flexGrow="0">
																	<label name="LblBrandAtenas" caption="Atenas" class="header-name header-name--accent" />
																</cell>
															</row>
														</table>
													</cell>
												</row>
												<row>
													<cell>
														<label name="LblPortalSub" caption="Nueva membresía" class="header-tagline" />
													</cell>
												</row>
											</responsive>
										</cell>
									</row>
								</table>
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
			<row>
				<cell horizontalAlignment="Center" verticalAlignment="Top">
					<responsive name="MainContent" class="page-content">
						<row>
							<cell horizontalAlignment="Center" verticalAlignment="Top">
								<responsive name="HeroBand" class="page-hero">
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<label name="LblTitulo" caption="Registrate como socio" class="text-title" />
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<label name="LblSubtitulo" caption="Completá tus datos y elegí tu plan." class="text-subtitle" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="DatosCard" class="surface">
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<label name="LblTusDatos" caption="Tus datos" class="surface-title" />
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Bottom">
											<label name="LblCedula" caption="Cédula *" class="field-label" />
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<input attribute="&amp;CedulaIngreso" class="field-input" />
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Bottom">
											<smart name="FilaLabelNombreApellido" columns="48%;4%;48%" width="100%" rows="48dip">
												<row>
													<cell>
														<label name="LblNombre" caption="Nombre *" class="field-label" />
													</cell>
													<cell />
													<cell>
														<label name="LblApellido" caption="Apellido *" class="field-label" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<smart name="FilaNombreApellido" columns="48%;4%;48%" width="100%" rows="52dip">
												<row>
													<cell>
														<input attribute="&amp;Nombre" class="field-input" />
													</cell>
													<cell />
													<cell>
														<input attribute="&amp;Apellido" class="field-input" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Bottom">
											<smart name="FilaLabelTelefonoEmail" columns="48%;4%;48%" width="100%" rows="48dip">
												<row>
													<cell>
														<label name="LblTelefono" caption="Celular *" class="field-label" />
													</cell>
													<cell />
													<cell>
														<label name="LblEmail" caption="Email *" class="field-label" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<smart name="FilaTelefonoEmail" columns="48%;4%;48%" width="100%" rows="52dip">
												<row>
													<cell>
														<input attribute="&amp;Telefono" class="field-input" />
													</cell>
													<cell />
													<cell>
														<input attribute="&amp;Email" class="field-input" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell />
						</row>
						<row>
							<cell>
								<responsive name="PlanesCard" class="surface">
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<label name="LblPlanes" caption="Elegí tu plan" class="surface-title" />
										</cell>
									</row>
									<row>
										<cell>
											<smart name="PlanAMensualRow" columns="56%;20%;24%" width="100%" class="plan-option" rows="34dip">
												<row>
													<cell>
														<smart name="PlanAMensualText" columns="100%" width="100%" rows="16dip;12dip">
															<row>
																<cell>
																	<label name="LblPlanAMensualName" caption="Socio A" class="plan-name" />
																</cell>
															</row>
															<row>
																<cell>
																	<label name="LblPlanAMensualMeta" caption="Mensual" class="plan-freq" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;PlanAMensualImporte" readonly="True" class="plan-price" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnElegirAMensual" onClickEvent="'ElegirAMensual'" caption="Seleccionar" class="plan-action" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="PlanAAnualRow" columns="56%;20%;24%" width="100%" class="plan-option" rows="34dip">
												<row>
													<cell>
														<smart name="PlanAAnualText" columns="100%" width="100%" rows="16dip;12dip">
															<row>
																<cell>
																	<label name="LblPlanAAnualName" caption="Socio A" class="plan-name" />
																</cell>
															</row>
															<row>
																<cell>
																	<label name="LblPlanAAnualMeta" caption="Anual · ahorrás $ 1.000" class="plan-freq" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;PlanAAnualImporte" readonly="True" class="plan-price" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnElegirAAnual" onClickEvent="'ElegirAAnual'" caption="Seleccionar" class="plan-action" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="PlanDBMensualRow" columns="56%;20%;24%" width="100%" class="plan-option" rows="34dip">
												<row>
													<cell>
														<smart name="PlanDBMensualText" columns="100%" width="100%" rows="16dip;12dip">
															<row>
																<cell>
																	<label name="LblPlanDBMensualName" caption="Socio D Básquet" class="plan-name" />
																</cell>
															</row>
															<row>
																<cell>
																	<label name="LblPlanDBMensualMeta" caption="Mensual" class="plan-freq" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;PlanDBasquetMensualImporte" readonly="True" class="plan-price" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnElegirDBasquetMensual" onClickEvent="'ElegirDBasquetMensual'" caption="Seleccionar" class="plan-action" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="PlanDBAnualRow" columns="56%;20%;24%" width="100%" class="plan-option" rows="34dip">
												<row>
													<cell>
														<smart name="PlanDBAnualText" columns="100%" width="100%" rows="16dip;12dip">
															<row>
																<cell>
																	<label name="LblPlanDBAnualName" caption="Socio D Básquet" class="plan-name" />
																</cell>
															</row>
															<row>
																<cell>
																	<label name="LblPlanDBAnualMeta" caption="Anual" class="plan-freq" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;PlanDBasquetAnualImporte" readonly="True" class="plan-price" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnElegirDBasquetAnual" onClickEvent="'ElegirDBasquetAnual'" caption="Seleccionar" class="plan-action" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="PlanDBBecaRow" columns="56%;20%;24%" width="100%" class="plan-option" rows="34dip">
												<row>
													<cell>
														<smart name="PlanDBBecaText" columns="100%" width="100%" rows="16dip;12dip">
															<row>
																<cell>
																	<label name="LblPlanDBBecaName" caption="Socio D Básquet" class="plan-name" />
																</cell>
															</row>
															<row>
																<cell>
																	<label name="LblPlanDBBecaMeta" caption="Beca 50%" class="plan-freq" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;PlanDBasquetBecaImporte" readonly="True" class="plan-price" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnElegirDBasquetBeca" onClickEvent="'ElegirDBasquetBeca'" caption="Seleccionar" class="plan-action" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell />
									</row>
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<label name="LblPlanElegido" caption="Plan elegido" class="info-label" />
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<input attribute="&amp;TipoCuotaNombre" readonly="True" class="info-value" />
										</cell>
									</row>
									<row>
										<cell />
									</row>
									<row>
										<cell>
											<action name="BtnRegistrarBottom" onClickEvent="'Registrar'" caption="Continuar al pago" class="btn-primary" />
										</cell>
									</row>
									<row>
										<cell />
									</row>
									<row>
										<cell>
											<action name="BtnVolverBottom" onClickEvent="'Volver'" caption="Volver" class="btn-secondary" />
										</cell>
									</row>
									<row>
										<cell />
									</row>
									<row>
										<cell horizontalAlignment="Center">
											<label name="LblPlanHintBottom" caption="Cuando elijas un plan, podés continuar desde aquí." class="field-help" />
										</cell>
									</row>
									<row>
										<cell />
									</row>
									<row>
										<cell horizontalAlignment="Center">
											<input attribute="&amp;MensajeError" readonly="True" class="message-inline" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell horizontalAlignment="Center">
								<label name="LblFooterPortal" caption="clubatenas.uy · Socios" class="page-footer" />
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
		</responsive>
		<actiongroups />
	</view>
</layout>