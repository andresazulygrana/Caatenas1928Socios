Procedure WebhookMercadoPago
{
	// Receptor HTTP del webhook de Mercado Pago
	Log.Info(!"WebhookMercadoPago RequestBody: " + Substr(&RequestBody, 1, 2000), !"$Atenas.MP.Webhook")

	If &RequestBody.IsEmpty()
		Log.Warning(!"WebhookMercadoPago body vacio", !"$Atenas.MP.Webhook")
		&RestCode = 200
		Return
	EndIf

	&Notification.FromJson(&RequestBody)

	If &Notification.Type = !"payment"
		If NOT &Notification.Data.Id.IsEmpty()
			&PaymentId = Trim(&Notification.Data.Id)
			Log.Info(!"WebhookMercadoPago PaymentId: " + &PaymentId, !"$Atenas.MP.Webhook")
			ProcesarPagoMercadoPago(&PaymentId)
		Else
			Log.Warning(!"WebhookMercadoPago payment sin Data.Id - body=" + Substr(&RequestBody, 1, 500), !"$Atenas.MP.Webhook")
		EndIf
	Else
		Log.Info(!"WebhookMercadoPago tipo ignorado=" + &Notification.Type, !"$Atenas.MP.Webhook")
	EndIf

	// Mercado Pago requiere siempre HTTP 200
	&RestCode = 200

	#Rules
		parm(in: &RequestBody);
	#End

	#Conditions
	#End

	#Variables
		RequestBody [ DataType = 'LongVarChar(4K)', Description = 'Cuerpo JSON del POST recibido de Mercado Pago' ]
		PaymentId [ DataType = 'VarChar(128)', Description = 'ID del pago extraido de la notificacion' ]
		Notification [ DataType = 'MercadoPagoWebhookNotification', Description = 'Webhook parseado recibido de Mercado Pago' ]
		RestCode [ DataType = 'Numeric(3.0)', Description = 'Codigo de respuesta HTTP - siempre 200 para webhooks MP' ]
		Pgmname [ DataType = 'Character(8)' ]
		Pgmdesc [ DataType = 'Character(8)' ]
	#End

	#Properties
		MainProgram = true
		CallProtocol = "HTTP"
	#End
}
