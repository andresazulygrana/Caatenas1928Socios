<layout type="Web">
	<view>
		<responsive name="Main" class="ContainerFluid PromptContainer" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:25},{&quot;width&quot;:75}]]}]">
			<row>
				<cell class="PromptAdvancedBarCell">
					<responsive name="AdvancedContainer" class="AdvancedContainerVisible" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
						<row>
							<cell>
								<responsive name="CuotaIdFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblCuotaIdFilter" caption="=CuotaId.Title" class="WWAdvancedLabel WWFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cCuotaId" labelPosition="None" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="SocioIdFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblSocioIdFilter" caption="=SocioId.Title" class="WWAdvancedLabel WWFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cSocioId" labelPosition="None" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="CuotaPeriodoFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblCuotaPeriodoFilter" caption="=CuotaPeriodo.Title" class="WWAdvancedLabel WWFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cCuotaPeriodo" labelPosition="None" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="CuotaImporteFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblCuotaImporteFilter" caption="=CuotaImporte.Title" class="WWAdvancedLabel WWFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cCuotaImporte" labelPosition="None" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="CuotaEstadoFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblCuotaEstadoFilter" caption="=CuotaEstado.Title" class="WWAdvancedLabel WWFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cCuotaEstado" labelPosition="None" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="CuotaFechaVencimientoFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblCuotaFechaVencimientoFilter" caption="=CuotaFechaVencimiento.Title" class="WWAdvancedLabel WWDateFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cCuotaFechaVencimiento" labelPosition="None" flatDatepicker="True" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="CuotaFechaPagoFilterContainer" class="AdvancedContainerItem AdvancedContainerItemExpanded" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]}]">
									<row>
										<cell>
											<label name="LblCuotaFechaPagoFilter" caption="=CuotaFechaPago.Title" class="WWAdvancedLabel WWDateFilterLabel" gxFormat="HTML" />
										</cell>
									</row>
									<row>
										<cell class="WWFiltersCell">
											<input attribute="&amp;cCuotaFechaPago" labelPosition="None" flatDatepicker="True" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
					</responsive>
				</cell>
				<cell class="WWGridCell">
					<responsive name="GridTable" responsiveSizes="[{&quot;scale&quot;:&quot;sm&quot;,&quot;rows&quot;:[[{&quot;visible&quot;:false}],[{&quot;width&quot;:100}],[{&quot;width&quot;:100}]]},{&quot;scale&quot;:&quot;xs&quot;,&quot;rows&quot;:[[{&quot;width&quot;:100}]]},{&quot;scale&quot;:&quot;md&quot;,&quot;rows&quot;:[[{&quot;visible&quot;:false}]]},{&quot;scale&quot;:&quot;lg&quot;,&quot;rows&quot;:[[{&quot;visible&quot;:false}]]}]">
						<row>
							<cell class="ToggleCell">
								<action name="BtnToggle" onClickEvent="'Toggle'" caption="|||" class="BtnToggle" />
							</cell>
						</row>
						<row>
							<cell>
								<tabularGrid name="Grid1" class="PromptGrid" maxRows="10">
									<input attribute="&amp;LinkSelection" title="" class="SelectionAttribute" columnClass="WWActionColumn" returnOnClick="True" />
									<input attribute="CuotaId" title="=CuotaId.ContextualTitle" columnClass="WWColumn" />
									<input attribute="SocioId" title="=SocioId.ColumnTitle" columnClass="WWColumn OptionalColumn" />
									<input attribute="CuotaPeriodo" title="=CuotaPeriodo.ContextualTitle" class="DescriptionAttribute" columnClass="WWColumn" returnOnClick="True" readOnly="True" />
									<input attribute="CuotaImporte" title="=CuotaImporte.ContextualTitle" columnClass="WWColumn OptionalColumn" />
								</tabularGrid>
							</cell>
						</row>
						<row>
							<cell>
								<action name="btn_cancel" onClickEvent="Cancel" caption="GX_BtnCancel" class="BtnCancel" />
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
		</responsive>
	</view>
</layout>