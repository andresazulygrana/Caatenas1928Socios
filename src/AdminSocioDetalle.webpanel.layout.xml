<layout type="Web">
	<view>
		<smart name="MainLayout" columns="100%" rows="100%" width="100%" height="100%" class="backoffice-page">
			<row>
				<cell horizontalAlignment="Center" verticalAlignment="Top">
					<smart name="Shell" columns="270px;100%" rows="100%" width="100%" height="100%" class="backoffice-shell">
						<row>
							<cell class="backoffice-sidebar" verticalAlignment="Top">
								<smart name="SidebarLayout" columns="100%" rows="74px;98px;392px;58px" width="100%">
									<row>
										<cell verticalAlignment="Top">
											<smart name="Brand" columns="56px;100%" rows="56px" width="100%">
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<label name="LblCrest" caption="A" class="backoffice-crest" />
													</cell>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<smart name="BrandText" columns="100%" rows="30px;18px" width="100%">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblBrandTitle" caption="Club Atenas" class="backoffice-brand-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Top">
																	<label name="LblBrandMeta" caption="Backoffice de socios" class="backoffice-brand-meta" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<smart name="SidebarCard" columns="100%" rows="18px;52px" width="100%" class="backoffice-sidebar-card">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblSidebarTitle" caption="Ficha del socio" class="backoffice-sidebar-section" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblSidebarText" caption="Edicion rapida, historial de cuotas y acciones de periodo sin salir del contexto." class="backoffice-sidebar-text" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Top">
											<smart name="SidebarNav" columns="100%" rows="44px;44px;44px;44px;44px;44px;44px;44px" width="100%">
												<row>
													<cell>
														<action name="BtnNavDashboard" onClickEvent="'Dashboard'" caption="Dashboard" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavSocios" onClickEvent="'Socios'" caption="Socios" class="btn-sidebar-active" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavImportar" onClickEvent="'ImportarSocios'" caption="Importar socios" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavTipos" onClickEvent="'TiposCuota'" caption="Tipos de cuota" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavCuotas" onClickEvent="'Cuotas'" caption="Cuotas" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavConfig" onClickEvent="'ConfiguracionPago'" caption="Configuracion pago" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavPruebas" onClickEvent="'PruebasPago'" caption="Prueba de pago" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavSandbox" onClickEvent="'Sandbox'" caption="Procesar sandbox" class="btn-sidebar" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Bottom">
											<label name="LblSidebarFooter" caption="Usuario: Secretaria Atenas | Admin / Operacion diaria" class="backoffice-sidebar-footer" />
										</cell>
									</row>
								</smart>
							</cell>
							<cell class="backoffice-main" verticalAlignment="Top">
								<smart name="DetalleBody" columns="100%" rows="128px;520px;28px;320px" width="100%" class="backoffice-main-body">
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="TopbarDetalle" columns="62%;38%" rows="44px;26px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblTitulo" caption="Detalle de socio" class="admin-topbar-title" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<smart name="TopbarActions" columns="50%;50%" rows="44px" width="100%">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<action name="BtnVolver" onClickEvent="'Volver'" caption="Volver a socios" class="btn-secondary" />
																</cell>
																<cell horizontalAlignment="Right" verticalAlignment="Middle">
																	<action name="BtnGuardarTop" onClickEvent="'Guardar'" caption="Guardar cambios" class="btn-primary" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<label name="LblDetalleSubtitulo" caption="Edicion puntual, resumen financiero y acciones claras para operar sobre el socio." class="admin-topbar-text" />
													</cell>
													<cell />
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Top">
											<smart name="BloquesDatos" columns="50%;50%" rows="520px" width="100%">
												<row>
													<cell verticalAlignment="Top">
														<smart name="DatosPersonales" columns="100%" rows="24px;24px;46px;24px;46px;24px;46px;24px;46px;24px;46px" width="100%" class="surface-elevated">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblDatosPersonalesTitle" caption="Datos personales" class="admin-card-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCedula" caption="Cedula" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;Cedula" readonly="True" class="field" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblNombre" caption="Nombre" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;Nombre" class="field" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblApellido" caption="Apellido" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;Apellido" class="field" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblEmail" caption="Email" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;Email" class="field" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblTelefono" caption="Telefono" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;Telefono" class="field" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell verticalAlignment="Top">
														<smart name="EstadoAcciones" columns="100%" rows="24px;24px;46px;24px;46px;24px;24px;40px;46px;46px" width="100%" class="surface-elevated">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblEstadoAccTitle" caption="Resumen y acciones" class="admin-card-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblEstado" caption="Estado (A activo, M moroso, I inactivo)" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;Estado" class="field" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblTipoCuota" caption="Tipo de cuota" class="field-label" />
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;TipoCuotaId" class="field" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblTipoCuotaNombre" caption="Descripcion actual del plan" class="field-label" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;TipoCuotaNombre" readonly="True" class="helper-text" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;Mensaje" readonly="True" class="helper-text" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<action name="BtnGuardar" onClickEvent="'Guardar'" caption="Guardar cambios" class="btn-primary" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<action name="BtnGenerarCuota" onClickEvent="'GenerarCuota'" caption="Generar cuota" class="btn-secondary" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<label name="LblHistorial" caption="Historial de cuotas" class="admin-section-title" />
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Top">
											<smart name="CuotasContainer" columns="100%" rows="40px;280px" width="100%" class="grid-wrap">
												<row>
													<cell verticalAlignment="Middle">
														<smart name="CabeceraCuotas" columns="20%;17%;14%;24%;25%" rows="40px" width="100%" class="grid-head">
															<row>
																<cell verticalAlignment="Middle">
																	<label name="LblCuotaPeriodo" caption="Periodo" class="grid-col-head" />
																</cell>
																<cell verticalAlignment="Middle">
																	<label name="LblCuotaImporte" caption="Importe" class="grid-col-head" />
																</cell>
																<cell verticalAlignment="Middle">
																	<label name="LblCuotaEstado" caption="Estado" class="grid-col-head" />
																</cell>
																<cell verticalAlignment="Middle">
																	<label name="LblCuotaVenc" caption="Vencimiento" class="grid-col-head" />
																</cell>
																<cell verticalAlignment="Middle">
																	<label name="LblCuotaPago" caption="Fecha de pago" class="grid-col-head" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell verticalAlignment="Top">
														<grid name="GridCuotas" ControlType="SDSmartGrid" class="grid-body">
															<table name="GridCuotasItem" columns="20%;17%;14%;24%;25%" rows="48px" width="100%">
																<row>
																	<cell verticalAlignment="Middle">
																		<input attribute="CuotaPeriodo" readonly="True" class="grid-col-text" />
																	</cell>
																	<cell verticalAlignment="Middle">
																		<input attribute="CuotaImporte" readonly="True" class="grid-col-text" />
																	</cell>
																	<cell verticalAlignment="Middle">
																		<input attribute="CuotaEstado" readonly="True" class="grid-col-meta" />
																	</cell>
																	<cell verticalAlignment="Middle">
																		<input attribute="CuotaFechaVencimiento" readonly="True" class="grid-col-meta" />
																	</cell>
																	<cell verticalAlignment="Middle">
																		<input attribute="CuotaFechaPago" readonly="True" class="grid-col-meta" />
																	</cell>
																</row>
															</table>
														</grid>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
		<actiongroups />
	</view>
</layout>