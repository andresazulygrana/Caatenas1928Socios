<layout type="Web">
	<view>
		<smart name="MainLayout" columns="100%" rows="100%" width="100%" height="100%" class="backoffice-page">
			<row>
				<cell horizontalAlignment="Center" verticalAlignment="Top">
					<smart name="Shell" columns="270px;100%" rows="100%" width="100%" height="100%" class="backoffice-shell">
						<row>
							<cell class="backoffice-sidebar" verticalAlignment="Top">
								<smart name="SidebarLayout" columns="100%" rows="74px;98px;392px;58px" width="100%">
									<row>
										<cell verticalAlignment="Top">
											<smart name="Brand" columns="56px;100%" rows="56px" width="100%">
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<label name="LblCrest" caption="A" class="backoffice-crest" />
													</cell>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<smart name="BrandText" columns="100%" rows="30px;18px" width="100%">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblBrandTitle" caption="Club Atenas" class="backoffice-brand-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Top">
																	<label name="LblBrandMeta" caption="Backoffice de socios" class="backoffice-brand-meta" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<smart name="SidebarCard" columns="100%" rows="18px;52px" width="100%" class="backoffice-sidebar-card">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblSidebarTitle" caption="Padron y deuda" class="backoffice-sidebar-section" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblSidebarText" caption="Navegacion fija por socios, cuotas, importacion y pruebas sin depender del master." class="backoffice-sidebar-text" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Top">
											<smart name="SidebarNav" columns="100%" rows="44px;44px;44px;44px;44px;44px;44px;44px" width="100%">
												<row>
													<cell>
														<action name="BtnNavDashboard" onClickEvent="'Dashboard'" caption="Dashboard" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavSocios" onClickEvent="'Socios'" caption="Socios" class="btn-sidebar-active" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavImportar" onClickEvent="'ImportarSocios'" caption="Importar socios" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavTipos" onClickEvent="'TiposCuota'" caption="Tipos de cuota" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavCuotas" onClickEvent="'Cuotas'" caption="Cuotas" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavConfig" onClickEvent="'ConfiguracionPago'" caption="Configuracion pago" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavPruebas" onClickEvent="'PruebasPago'" caption="Prueba de pago" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavSandbox" onClickEvent="'Sandbox'" caption="Procesar sandbox" class="btn-sidebar" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Bottom">
											<label name="LblSidebarFooter" caption="Usuario: Secretaria Atenas | Admin / Operacion diaria" class="backoffice-sidebar-footer" />
										</cell>
									</row>
								</smart>
							</cell>
							<cell class="backoffice-main" verticalAlignment="Top">
								<smart name="SociosBody" columns="100%" rows="128px;28px;784px;72px" width="100%" class="backoffice-main-body">
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="TopbarSocios" columns="100%" rows="44px;26px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblTitulo" caption="Socios" class="admin-topbar-title" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<label name="LblSubtituloSocios" caption="Padron operativo con filtro simple, lectura rapida y acceso directo al detalle." class="admin-topbar-text" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<label name="LblListado" caption="Listado de socios" class="admin-section-title" />
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Top">
											<smart name="BloqueSocios" columns="100%" rows="142px;624px" width="100%">
												<row>
													<cell verticalAlignment="Middle">
														<smart name="FiltroSocios" columns="55%;20%;25%" rows="28px;58px" width="100%" class="surface-elevated">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblBusqueda" caption="Nombre, apellido o cedula" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblEstado" caption="Estado socio" class="field-label" />
																</cell>
																<cell />
															</row>
															<row>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;TextoBusqueda" class="field" />
																</cell>
																<cell verticalAlignment="Middle">
																	<input attribute="&amp;FiltroEstado" class="field" />
																</cell>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<action name="BtnBuscar" onClickEvent="'Buscar'" caption="Buscar" class="btn-primary" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell verticalAlignment="Top">
														<smart name="GridContainer" columns="100%" rows="40px;584px" width="100%" class="grid-wrap">
															<row>
																<cell verticalAlignment="Middle">
																	<smart name="CabeceraGrid" columns="18%;30%;14%;12%;16%;10%" rows="40px" width="100%" class="grid-head">
																		<row>
																			<cell verticalAlignment="Middle">
																				<label name="LblColCedula" caption="Cedula" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColNombre" caption="Nombre" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColTipo" caption="Tipo cuota" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColEstado" caption="Estado" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColPendiente" caption="Pendiente / cuota" class="grid-col-head" />
																			</cell>
																			<cell horizontalAlignment="Center" verticalAlignment="Middle">
																				<label name="LblColAccion" caption="Accion" class="grid-col-head" />
																			</cell>
																		</row>
																	</smart>
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Top">
																	<grid name="GridSocios" ControlType="SDSmartGrid" class="grid-body">
																		<table name="GridSociosItem" columns="18%;30%;14%;12%;16%;10%" rows="60px" width="100%">
																			<row>
																				<cell verticalAlignment="Middle">
																					<input attribute="&amp;CedulaFila" readonly="True" class="grid-col-text" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="&amp;NombreFila" readonly="True" class="grid-col-text" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="&amp;TipoCuotaFila" readonly="True" class="grid-col-meta" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<smart name="EstadoFilaPills" columns="100%" rows="20px;20px;20px" width="100%">
																						<row>
																							<cell horizontalAlignment="Left" verticalAlignment="Middle">
																								<input attribute="&amp;EstadoActivoTextoFila" readonly="True" class="admin-pill-ok" />
																							</cell>
																						</row>
																						<row>
																							<cell horizontalAlignment="Left" verticalAlignment="Middle">
																								<input attribute="&amp;EstadoMorosoTextoFila" readonly="True" class="admin-pill-danger" />
																							</cell>
																						</row>
																						<row>
																							<cell horizontalAlignment="Left" verticalAlignment="Middle">
																								<input attribute="&amp;EstadoPendienteTextoFila" readonly="True" class="admin-pill-warn" />
																							</cell>
																						</row>
																					</smart>
																				</cell>
																				<cell verticalAlignment="Middle">
																					<smart name="EstadoCuotaFila" columns="100%" rows="28px;28px" width="100%">
																						<row>
																							<cell verticalAlignment="Middle">
																								<input attribute="&amp;PendienteFila" readonly="True" class="grid-col-meta" />
																							</cell>
																						</row>
																						<row>
																							<cell verticalAlignment="Middle">
																								<input attribute="&amp;ProximaCuotaFila" readonly="True" class="grid-col-meta" />
																							</cell>
																						</row>
																					</smart>
																				</cell>
																				<cell horizontalAlignment="Center" verticalAlignment="Middle">
																					<action name="BtnVerDetalle" onClickEvent="'VerDetalle'" caption="Ver" class="btn-sm-primary" />
																				</cell>
																			</row>
																		</table>
																	</grid>
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell class="page-footer admin-pager-host" horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="PaginacionBar" columns="22%;56%;22%" rows="44px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<action name="BtnPaginaAnterior" onClickEvent="'PaginaAnterior'" caption="Anterior" class="btn-secondary" />
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;ResumenPaginacion" readonly="True" class="text-caption" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnPaginaSiguiente" onClickEvent="'PaginaSiguiente'" caption="Siguiente" class="btn-primary" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
	</view>
</layout>