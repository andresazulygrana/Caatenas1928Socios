Module GeneXusReporting
{
	<ExportFile><Objects><Object parentGuid="634922c3-27ba-4d2f-8e8f-91ce48da70b2" user="GeneXus" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2023-07-26T16:44:23.0000000Z" checksum="e6eba1cc7704da2cd1543c06fd8767aa" fullyQualifiedName="GeneXusReporting.DashboardViewerWeb" moduleGuid="8d6bd4ab-a1a0-422d-a589-fb9e0cd18539" guid="fbf032cc-545a-449c-813d-de6ef00c7b43" name="DashboardViewerWeb" type="78b3fa0e-174c-4b2b-8716-718167a428b5" description="Dashboard Viewer Web" parent="GeneXusReporting.Unanimo" parentType="00000000-0000-0000-0000-000000000008"><Part type="75e52d99-6edd-4bad-a1d7-dcc9b7f000ef"><Source>tokens DashboardViewer (color-scheme:dark|[light])

	{

	     

	    @color-scheme = light {

	

	        ##borders

	        {

	        gxqv-border: #e0e0e0;

	        }

	

	    }

	    

	    @color-scheme = dark {

	

	        ##borders

	        {

	        gxqv-border: #242426;

	        }

	

	    }

	

	}</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="c6b14574-4f5f-4e35-aaa7-e322e88a9a10"><Source>styles DashboardViewer {

	

	    @import GeneXusUnanimo.UnanimoWeb;

	

	    .gx-db

	    { 

	        font-family: $fonts.primary-regular; 

	        font-size: $fontSizes.s; 

	    }

	

	    .gx-db .material-icons

	    {

	        color: $colors.primary;

	    }

	

	    .gx-db-widget .gx-db-filter-value.checkbox-inline

	    {

	        color: $colors.on-background;

	    }

	

	    .gx-db-widget

	    {

	        padding: $spacing.inset-s;

	        width: 100%;

	    }

	

	    .panel-collapse collapse in

	    {

	        display: block;    

	    }

	

	    .panel-collapse collapse

	    {

	        display: none;

	    }

	

	    .gx-db-title

	    {

	        @include heading-01;

	        color: $colors.surface-negative;

	    }

	

	    .gx-db-title &gt; div

	    {

	        @include heading-01;

	        text-align: start !important;

	        padding-left: $spacing.inline-l;

	        padding-bottom: $spacing.stack-xl;

	    }

	

	    .gx-db-widget-frame &gt; div:nth-child(2)

	    {

	        border-top: $borders.extra-small solid $colors.gray01;

	    }

	

	    .gx-db-widget-frame-title

	    {

	        height: 48px;

	        border-bottom-width: 0px;

	        padding-top: $spacing.inset-s !important;

	        padding-inline-start: $spacing.inset-m !important;

	    }

	

	    .gx-db-widget-frame-title div:first-child

	    {

	        line-height:30px;

	        color: $colors.on-background;

	        font-family: $fonts.primary-bold;

	        font-size: $fontSizes.s;

	        font-weight: bold;

	        height: 20px;

	        letter-spacing: 0.38px;

	    }

	

	    .gx-db-widget-frame-collapse-image:after

	    {

	        width: 20px;

	        background-image: gx-image(GeneXusReporting.asc) !important;

	        background-repeat: no-repeat;

	        background-position: -6px -1px;

	        margin-right: $spacing.inline-m;

	        margin-top: $spacing.inline-m;

	        color: transparent;

	    }

	

	    .gx-db-widget-frame-collapse-image.collapsed:after

	    {

	        background-image: gx-image(GeneXusReporting.desc) !important;

	        background-position: -1px -1px;

	        width: 20px;

	        color: transparent;

	        cursor: pointer;

	        margin-inline-end: $spacing.inline-l;

	        margin-top: $spacing.inline-m;

	        margin-inline-start: $spacing.inline-xs !important;

	    }

	

	    .panel

	    {

	        background-color: $colors.elevation-01;

	        border-radius: $radius.xl;

	        box-shadow: $shadows.xxxs;

	        border: $borders.extra-small solid $borders.gxqv-border;

	    }

	

	    .panel-heading

	    {

	        box-shadow: unset;

	        padding-top: $spacing.stack-m;

	        border-radius: $radius.xl;

	    }

	

	    .panel-default&gt;.panel-heading

	    {

	        background-color: $colors.elevation-01;

	        box-shadow: unset;

	    }

	

	    .panel-collapse, .panel-body

	    {

	        padding: $spacing.inset-m;

	    }

	    

	    .gx-db-widget input[type=checkbox] + i

	    {

	        color:  $colors.primary;

	    }

	

	    .gx-db-textblock

	    {

	        color: $colors.on-background;

	    }

	

	    /*****************FormControl***************/

	

	    .gx-db-filter-value.form-control

	    {

	        width:100%;

	        padding: 6px 12px;

	        min-height: 34px;

	        font-size: $fontSizes.s;

	        border: $borders.extra-small solid $colors.gray01;

	        border-radius: $radius.l;

	        box-shadow: inset $shadows.xxxs;

	        font-family: $fonts.primary-regular;

	        background-color: $colors.elevation-01;

	        color: $colors.on-background;

	    }

	

	    .gx-db-filter-value.form-control.gx-db-date-filter, .gx-db-filter-value.form-control.gx-db-datetime-filter

	    {

	        background-image: gx-image(GeneXusReporting.arrow_double);

	        background-position: right;

	        background-repeat: no-repeat;

	        background-size: $spacing.line-height-s;

	        text-align: left;

	        padding-left: $spacing.inline-l;

	    }

	

	    .gx-db-filter-value.form-control.gx-db-date-filter

	    {

	        width: 14ch;

	        max-width: 100%;

	    }

	

	    .gx-db-filter-value.form-control.gx-db-date-filter.gx-db-range-filter

	    {

	        width: 25ch;

	        max-width: 100%;

	    }

	

	    .gx-db-filter-value.form-control.gx-db-datetime-filter

	    {

	        width: 24ch;

	        max-width: 100%;

	    }

	

	    .gx-db-filter-value.form-control.gx-db-datetime-filter.gx-db-range-filter

	    {

	        width: 45ch;

	        max-width: 100%;

	    }

	

	    .gx-db-filters-table.gx-db-horizontal-filters .gx-db-filter-value.form-control

	    {

	        max-width: 25vw;

	    }

	

	    input.gx-db-filter-value.form-control.gx-db-value-filter.gx-db-numeric-filter

	    {

	        text-align: right;

	    }

	

	    .gx-db-filter-value.form-control:focus

	    {

	        border: $borders.small solid $colors.secondary;

	        box-shadow: $shadows.xxxs;

	    }

	

	    .gx-db-filter-value.form-control:active

	    {

	        border: $borders.small solid $colors.secondary;

	    }

	

	    .gx-db-filter-value.form-control:disabled

	    {

	        border: $borders.extra-small solid $colors.gray03;

	        color: $colors.gray03;

	        background-color: $colors.gray01;

	    }

	    

	    .gx-db-filter-value.form-control:error

	    {

	        border: $borders.extra-small solid $colors.error-dark;

	    }

	        

	    .gx-db-filter-value .form-control &gt; option

	    {

	        background: $colors.on-background;

	        height: 20px;

	        border-radius: $radius.xl;

	        box-shadow: inset $shadows.xxs;

	        font-family: $fonts.primary-regular; 

	    }

	

	    .gx-db-filter-caption

	    {

	        @include attribute-label;

	        color: $colors.on-background;

	        font-family: $fonts.primary-semibold;

	        font-size: $fontSizes.s;

	    }

	

	    /****************Select**********************/

	

	    .gx-db-widget select

	    {

	        appearance: none;

	        font-size: $fontSizes.s;

	        background-image: gx-image(GeneXusReporting.arrow_double);

	        background-position: right;

	        background-repeat: no-repeat;

	        background-size: $spacing.line-height-s;

	        text-align: left;

	        padding-left: 12px !important;

	        padding-right: 20px;

	        height: 32px !important;

	        text-align: left;

	        border: $borders.extra-small solid $colors.gray01;

	        border-radius: $radius.l;

	        box-shadow: inset $shadows.xxxs;

	        font-family: $fonts.primary-regular;

	        background-color: $colors.elevation-01;

	        color: $colors.on-background;

	        opacity: 1 !important;

	    }

	

	    .gx-db-widget select &gt; option

	    {

	        color: $colors.surface-negative;

	        font-family: $fonts.primary-regular;

	        font-size: $fontSizes.s;

	        height: 15px;

	        letter-spacing: $spacing.letter-spacing-xs;

	        line-height: 16px;

	        background: $colors.elevation-01;

	        border-radius: $radius.xl;

	        box-shadow: $shadows.xxs;

	        padding-top: $spacing.stack-m;

	        padding-bottom: $spacing.stack-m;

	    }

	

	    .gx-db-filters-table.gx-db-horizontal-filters .gx-db-widget select

	    {

	        max-width: 25vw;

	    }

	

	    select.bs-select-hidden, .bootstrap-select &gt; select.bs-select-hidden, select.selectpicker

	    {

	        display: block !important;

	    }

	

	    .gx-db-widget .bootstrap-select

	    {

	        vertical-align: middle;

	        position: relative;

	    }

	

	    .gx-db-widget .bootstrap-select ul

	    {

	        border-radius: 0px;

	    }

	

	    .gx-db-filters-table.gx-db-horizontal-filters .bootstrap-select

	    {

	        max-width: 25vw;

	    }

	

	    /**********************DataPicker************************/

	

	    .calendar-table th

	    {

	        border: 0px solid !important;

	        color: $colors.primary !important;

	    }

	

	    .daterangepicker

	    {

	        border-radius: $radius.l;

	        border: $borders.extra-small solid $colors.gray01;

	        padding: $spacing.inset-xs;

	        margin-top: $spacing.stack-xs;

	        display: none;

	        font-family: $fonts.primary-regular;

	        font-size: $fontSizes.s;

	        background-color: $colors.elevation-02;

	    }

	

	    .daterangepicker.dropup

	    {

	        margin-top: -5px; 

	    }

	

	    .daterangepicker td.active, .daterangepicker td.active:hover

	    {

	        background: $colors.primary-hover-20;

	        border-radius: 0px;

	        border: $borders.extra-small solid $colors.primary;

	        color: $colors.on-alert;

	    }

	

	    .in-range available

	    {

	        background: $colors.primary-hover-20;

	        border-radius: 0px;

	        border: $borders.extra-small solid $colors.primary;

	        color: $colors.on-alert;

	    }

	

	    .next available .prev available

	    {

	        border: 0px solid;

	    }

	    

	    .daterangepicker .calendar-table

	    {

	        border: 0px solid !important;

	    }

	

	    .daterangepicker .calendar-table td

	    {

	        border: $borders.extra-small solid $colors.gray01;

	    }

	

	    .daterangepicker .calendar-table table

	    {

	        margin: 0;

	        border-radius: 0px;

	        border-spacing: 2px;

	        border-collapse: separate;

	        background-color: $colors.elevation-02;

	    }

	

	    .daterangepicker td.off, .daterangepicker td.off.in-range, .daterangepicker td.off.start-date, .daterangepicker td.off.end-date

	    {

	        color: $colors.secondary-disabled;

	    }

	    

	    .daterangepicker td.start-date.end-date

	    {

	        background: $colors.primary-hover-20;

	        border-radius:  0px;

	        border: $borders.extra-small solid $colors.primary !important;

	        color: $colors.on-background;

	    }

	

	    .active.start-date.available

	    {

	        background: $colors.primary-hover-20;

	        border-radius:  0px;

	        border: $borders.extra-small solid $colors.primary !important;

	        color: $colors.on-background;

	    }

	

	    .daterangepicker select.monthselect, .daterangepicker select.yearselect

	    {

	        text-align: center;

	        color: $colors.on-background;

	        font-family: $fonts.primary-bold;

	        font-size: $fontSizes.s;

	        font-weight: bold;

	        background-color: $colors.elevation-02;

	    }

	

	    .daterangepicker &gt; select.monthselect

	    {

	        border: 0px solid;

	        appearance: none;

	    }

	

	    .daterangepicker &gt; select.yearselect

	    {

	        border: 0px solid;

	        appearance: none;

	        text-align: left;

	    }

	

	    .active start-date active end-date available

	    {

	        background: $colors.primary-hover-20;

	        border-radius: 0px;

	        border: $borders.extra-small solid $colors.primary;

	        color: $colors.on-alert;

	    }

	

	    .available

	    {

	        border-radius: 0px;

	        border: $borders.extra-small solid $colors.gray02;

	    }

	

	    .daterangepicker select.hourselect, .daterangepicker select.minuteselect, .daterangepicker select.secondselect, .daterangepicker select.ampmselect

	    {

	        font-family: unset;

	        border-radius: $radius.l;

	        border: $borders.extra-small solid $colors.gray01;

	        height: 27px;

	        width: 48px;

	        background: $colors.elevation-02;

	        color: $colors.on-background;

	    }

	

	    .daterangepicker .drp-buttons .btn

	    {

	        font-family: unset;

	        margin: 0px auto;

	        padding: $spacing.inset-xs;

	        margin-left: $spacing.inline-l;

	        outline: 0;

	        border-radius: $radius.l;

	        border: $borders.extra-small solid $colors.primary;

	        height: 27px;

	        width: 48px;

	        background: $colors.elevation-02;

	        color: $colors.primary;

	    }

	

	    .daterangepicker.drp-buttons.btn:hover

	    {

	        margin: 0px auto;

	        padding: $spacing.inset-xs;

	        margin-left: $spacing.inline-l;

	        outline: 0;

	        border-radius: $radius.l;

	        border: $borders.extra-small solid $colors.primary;

	        height: 27px;

	        width: 48px;

	        background: $colors.primary;

	        color: $colors.on-primary;

	    }

	

	    .daterangepicker.drp-buttons.btn:active

	    {

	        margin: 0px auto;

	        padding: $spacing.inset-xs;

	        margin-left: $spacing.inline-l;

	        outline: 0;

	        border-radius: $radius.l;

	        border: $borders.extra-small solid $colors.primary;

	        height: 27px;

	        width: 48px;

	        background: $colors.primary;

	        color: $colors.on-primary;

	    }

	

	    .daterangepicker .calendar-time

	    {

	        margin: $spacing.inset-xs auto;

	    }

	

	    .table-condensed &gt; thead &gt; tr

	    {

	        color: $colors.primary;

	    }

	

	    .drp-calendar.left .drp-calendar.single

	    {

	        display: block;

	        background: $colors.on-background;

	        border-radius: 0px;

	        box-shadow: $shadows.xs;

	        height: 195px;

	        width: 200px;

	        padding-left: $spacing.inline-xs;

	        padding-top: $spacing.stack-xs;

	        padding-bottom: $spacing.stack-xs;

	        padding-right: $spacing.inline-xs;

	    }

	    

	    .daterangepicker .drp-calendar.left.single

	    {

	        padding: 3px;

	    }

	

	    .daterangepicker .drp-calendar.right

	    {

	        padding: 3px 3px 3px 7px;

	    }

	

	    .daterangepicker .drp-calendar.left

	    {

	        padding: 3px 7px 3px 3px;

	    }

	

	    .daterangepicker td.available:hover, .daterangepicker th.available:hover

	    {

	        background: $colors.primary-hover-20;

	        border-radius:  0px;

	        border: $borders.extra-small solid $colors.primary !important;

	        color: $colors.on-background;

	    }

	    

	    .daterangepicker .drp-calendar.left .calendar-table

	    {

	        padding-right: 0px;

	    }

	

	    .daterangepicker .calendar-table th, .daterangepicker .calendar-table td

	    {

	        min-width: 24px;

	        width: 28px;

	        height: 26px;

	        line-height: 16px;     

	        font-size: $fontSizes.xs;

	        border-radius: 0px;

	        color: $colors.on-background;

	        background-color: $colors.elevation-02;

	

	    }

	

	    .off.ends.in-range.available

	    {

	        border: $borders.extra-small solid $colors.gray02;

	    }

	

	    .daterangepicker td.in-range

	    {

	        background: $colors.primary-hover-20;

	        border-radius: 0px;

	        border: $borders.extra-small solid $colors.primary;

	    }

	

	    .daterangepicker select.monthselect

	    {

	        border: 0px solid;

	        appearance: none;

	    }

	

	    .daterangepicker select.yearselect

	    {

	        border: 0px solid;

	        appearance: none;

	        text-align: left;

	    }

	

	    .table-condensed &gt; thead &gt; tr &gt; td

	    {

	        color: $colors.primary;

	    }

	

	    .daterangepicker.ltr.show-calendar.opensleft &gt; .drp-buttons &gt; .drp-selected 

	    {

	        color: $colors.on-background;

	    }

	

	    .daterangepicker .calendar-table .next span, .daterangepicker .calendar-table .prev span

	    {

	        border-color: $colors.on-background;

	    }

	

	

	    /**********************noUi************************/

	    

	    .noUi-connect .noUi-draggable

	    {

	        height: 2px;

	    }

	

	    .noUi-tooltip .gx-db-filter-value

	    {

	        padding-bottom: $spacing.stack-m;

	        color: $colors.primary;

	        font-size: $fontSizes.s;

	        font-weight: bold;

	    }

	

	    .noUi-target.noUi-ltr.noUi-horizontal

	    {

	        height: 2px;

	        border: 0px;

	    }

	

	    .noUi-horizontal .noUi-handle

	    {

	        left: -10px;

	        border-radius: 32px;

	        background: $colors.elevation-03;

	        border-color: $colors.elevation-03;

	        box-shadow: $shadows.xxs;

	        height: 12px;

	        width: 12px;

	        margin-left: $spacing.inline-m;

	    }

	

	    .noUi-handle:before

	    {

	        display: none;

	        left: 7px;

	    }

	

	    .noUi-handle:after

	    {

	        display: none;

	        left: 10px;

	    }

	

	    .noUi-horizontal .noUi-tooltip

	    {

	        bottom: 215%;

	        height: 5px;

	        padding-bottom: $spacing.stack-m;

	        color: $colors.primary;

	        font-size: $fontSizes.s;

	        font-weight: bold;

	    }

	

	    .noUi-connect

	    {

	        background-color: $colors.primary;

	    }

	

	    .noUi-base

	    {

	        height: 2px;

	        background-color: $colors.gray02;

	    }

	

	    .noUi-target

	    {

	        top: 20px;

	    }

	

	    .noUi-handle

	    {

	        margin-left: $spacing.inline-m;

	        cursor: pointer;

	        box-shadow: $shadows.xxs;

	    }

	

	    .noUi-horizontal

	    {

	        height: 2px;

	    }

	

	    .noUi-tooltip

	    {

	        border: none;

	        background: none;

	        padding: 0px;

	        bottom: -50%;

	    }

	

	    .noUi-handle-lower

	    {

	        width: 8px;

	        height: 8px;

	        margin-left: $spacing.inline-m;

	    }

	

	    .gx-db-filters-table.gx-db-horizontal-filters .noUi-horizontal, .gx-db-filters-table.gx-db-horizontal-filters .noUi-base

	    {

	        max-width: 25vw;

	    }

	

	    /**********************Buttons************************/

	

	    .gx-db-filter-value.btn.btn-default

	    {

	        overflow: hidden;

	        text-overflow: ellipsis;

	        height: 32px;

	        min-width: 60px;

	        font-size: $fontSizes.s;

	        font-weight: 600;

	        letter-spacing: $spacing.letter-spacing-xs;

	        text-align: center;

	        text-transform: uppercase;

	        border: $borders.extra-small solid $colors.primary;

	        color: $colors.primary;

	        font-family: $fonts.primary-semibold;

	        background-color: $colors.elevation-02;

	    }

	

	    .btn-group-vertical&gt;.btn-group:first-child&gt;.btn                 // first button (orientation = vertical)

	    {

	        border-top-right-radius: $radius.m;

	        border-top-left-radius: $radius.m;

	        border-bottom-right-radius: 0px;

	        border-bottom-left-radius: 0px;

	    }

	

	    .btn-group-vertical&gt;.btn-group:last-child&gt;.btn                  // last button (orientation = vertical)

	    {

	        border-top-right-radius: 0px;

	        border-top-left-radius: 0px;

	        border-bottom-right-radius: $radius.m;

	        border-bottom-left-radius: $radius.m;

	    }

	

	    .btn-group.btn-group-justified&gt;.btn-group:first-child&gt;.btn      // first button (orientation = horizontal)

	    {

	        border-top-right-radius: 0px;

	        border-top-left-radius: $radius.m;

	        border-bottom-right-radius: 0px;

	        border-bottom-left-radius: $radius.m;

	    }

	

	    .btn-group.btn-group-justified&gt;.btn-group:last-child&gt;.btn       // last button (orientation = horizontal)

	    {

	        border-top-right-radius: $radius.m;

	        border-top-left-radius: 0px;

	        border-bottom-right-radius: $radius.m;

	        border-bottom-left-radius: 0px;

	    }

	

	    .btn-group-vertical&gt;.btn, .btn-group-vertical&gt;.btn-group, .btn-group-vertical&gt;.btn-group&gt;.btn

	    {

	        display: block;

	        float: none;

	        width: 100%;

	        min-height: 38px; 

	    }

	

	    .gx-db-filters-table.gx-db-horizontal-filters .btn-group-vertical&gt;.btn-group

	    {

	        max-width: 25vw;

	    }

	    

	    .cancelBtn.btn.btn-sm.btn-default:hover

	    {

	        background-color: $colors.primary;

	        color: $colors.on-primary;

	        border: $borders.extra-small solid $colors.primary;

	    }

	

	    .applyBtn.btn.btn-sm.btn-primary:hover

	    {

	        background-color: $colors.primary;

	        color: $colors.surface;

	        border: $borders.extra-small solid $colors.primary;

	    }

	

	    .cancelBtn.btn.btn-sm.btn-default:focus

	    {

	        background-color: $colors.primary;

	        color: $colors.surface;

	        border: $borders.extra-small solid $colors.primary;

	    }

	

	    .applyBtn.btn.btn-sm.btn-primary:focus

	    {

	        background-color: $colors.primary;

	        color: $colors.on-primary;

	        border: $borders.extra-small solid $colors.primary;

	    }

	

	    .gx-db-filter-value.btn.btn-default.active

	    {

	        background-color: $colors.primary;

	        color: $colors.on-primary;

	    }

	

	    .gx-db-widget button

	    {

	        font-size: $fontSizes.m;

	    }

	

	    .gx-db-filter-value.btn.btn-default:hover

	    {

	        background: $colors.primary;

	        color: $colors.on-primary;

	    }

	

	    .btn-group-justified&gt;.btn, .btn-group-justified&gt;.btn-group

	    {

	        width: unset;

	    }

	

	    .btn-group-vertical&gt;.btn+.btn, .btn-group-vertical&gt;.btn+.btn-group, .btn-group-vertical&gt;.btn-group+.btn, .btn-group-vertical&gt;.btn-group+.btn-group

	    {

	        margin-top: -2px;

	    }

	

	    .gx-db-widget .btn, .gx-db-widget .checkbox-inline, .gx-db-widget .checkbox label

	    {

	        cursor: pointer;

	    }

	

	    /**********************DropDownMenu************************/

	

	    .gx-db-widget .open&gt;.dropdown-menu 

	    {

	        display: block;

	    }

	

	    .gx-db-widget .dropdown-menu 

	    {

	        display: none;

	    }

	

	    .gx-db-widget .dropup .dropdown-menu

	    {

	        bottom: 100%;

	        margin-bottom: 2px;

	    }

	

	    .btn.dropdown-toggle.gx-db-filter-value

	    {

	        border: $borders.extra-small solid $colors.gray01;

	        border-radius: $radius.l !important;

	        text-transform: capitalize;

	        color: $colors.on-background;

	        font-family: $fonts.primary-regular;

	        font-size: $fontSizes.s;

	        font-weight: normal;

	        padding-left: $spacing.inline-xl; 

	        padding-right: $spacing.inline-xl; 

	        background-color: $colors.elevation-01;

	        background-image: gx-image(GeneXusReporting.arrow_double);

	        background-position: right;

	        background-repeat: no-repeat;

	        background-size: $spacing.line-height-s;

	        height: 34px;

	        line-height: 16px;

	    }

	    

	    btn.dropdown-toggle.gx-db-filter-value.bs-placeholder

	    {

	        height: 34px;

	        font-size: $fontSizes.s;

	        border: $borders.extra-small solid $colors.gray01;

	        border-radius: $radius.l;

	        font-family: $fonts.primary-regular;

	        line-height: 14px;

	    }

	

	    .gx-db-widget .dropdown.bootstrap-select.show-tick.form-control.bs3

	    {

	        padding-top:0px; 

	        border: 0px solid;

	    }

	

	    .dropdown-menu.inner &gt; .no-results

	    {

	        background-color: $colors.elevation-02;

	        color: $colors.on-background;

	    } 

	

	    .bs-searchbox &gt; input

	    {

	        font-family: $fonts.primary-regular;

	        text-indent: $spacing.inline-xl;

	        height: 35px;

	        border-color: $colors.on-alert;

	        margin-left: 2px !important;

	        margin-top: 8px !important;

	        margin-bottom: $spacing.stack-xs;

	        border-radius: 4px;

	        background-color: $colors.elevation-01;

	        color: $colors.on-background;

	    }

	

	    .bs-actionsbox.btn-group.button

	    {

	        text-transform: uppercase;

	        height: 40px;

	        color: $colors.primary;

	        border-color: $colors.primary;

	        border-radius: $radius.m;

	        font-family: $fonts.primary-semibold;

	        font-size: $fontSizes.s;

	        background-color: $colors.elevation-02;

	        padding-left: $spacing.inline-xl; 

	        padding-right: $spacing.inline-xl; 

	    }

	

	    .dropdown-menu.open &gt; .bs-searchbox

	    {

	        padding-left: $spacing.inline-xl; 

	        padding-right: $spacing.inline-xl; 

	    }

	

	    .dropdown-menu.open &gt; .bs-actionsbox

	    {

	        padding-left: $spacing.inline-xl; 

	        padding-right: $spacing.inline-xl; 

	    }

	

	    .bs-caret &gt; .caret

	    {

	        display: none;

	    }

	

	    .dropdown-menu.inner &gt; li &gt; .gx-db-filter-value

	    {

	        margin-top: 0px;

	        margin-bottom: 0px;

	        padding-left: $spacing.inline-xl; 

	        padding-right: $spacing.inline-xl;

	        color: $colors.on-background;

	    }

	

	    .dropdown-menu.inner, .dropdown-menu.open

	    {

	        background: $colors.elevation-02;

	    }

	

	    .dropdown-menu.open &gt; .bs-searchbox &gt; .form-control

	    {

	        appearance: none;

	        background-position: left;

	        background-repeat: no-repeat;

	        background-image: gx-image(GeneXusReporting.search);

	        padding-left: 7px;

	    }

	

	    .gx-db-widget .dropdown-menu

	    {

	        z-index: 1000;

	    }

	

	    .actions-btn.bs-select-all.btn.btn-default

	    {

	        border-bottom-left-radius: $spacing.inline-m;

	        border-top-left-radius: $spacing.inline-m;

	        border: $borders.extra-small solid $colors.primary;

	        background-color: $colors.elevation-02;

	        font-size: $fontSizes.s;

	        text-transform: uppercase;

	        color: $colors.primary;

	        font-family: $fonts.primary-semibold;

	        min-height: 32px;

	        margin-left: $spacing.inline-xs;

	    }

	

	    .actions-btn.bs-deselect-all.btn.btn-default

	    {

	        border-bottom-right-radius: $spacing.inline-m;

	        border-top-right-radius: $spacing.inline-m;

	        border: $borders.extra-small solid $colors.primary;

	        background-color: $colors.elevation-02;

	        font-size: $fontSizes.s;

	        text-transform: uppercase;

	        color: $colors.primary;

	        font-family: $fonts.primary-semibold;

	        min-height: 32px;

	    }

	

	    .actions-btn.bs-deselect-all.btn.btn-default:hover, .actions-btn.bs-select-all.btn.btn-default:hover

	    {

	        background: $colors.primary;

	        color: $colors.on-primary;

	    }

	

	    /****************************Switch**************************/

	    

	    .gx-db-filters-table.gx-db-horizontal-filters .gx-db-switch-filter

	    {

	        max-width: 25vw;

	    }

	

	    .gx-db-widget .bootstrap-switch

	    {

	        overflow: visible !important;

	        width: 42px !important;

	        float: none !important;

	    }        

	

	    .gx-db-widget .bootstrap-switch-container

	    {

	        position: relative;

	        height: 10px;

	    }

	

	    .gx-db-widget .bootstrap-switch-label

	    {

	        position: relative;

	        top: -6px;

	        left: -1px;

	        background: $colors.elevation-01;

	    }

	

	    .gx-db-widget .bootstrap-switch.bootstrap-switch-focused

	    {

	        box-shadow: unset;

	        -webkit-box-shadow: unset;

	

	    }

	

	    .gx-db-widget .bootstrap-switch-on .bootstrap-switch-label

	    {

	        background: $colors.primary-active;

	    }

	

	    .gx-db-widget .bootstrap-switch-on

	    {

	        background-color: $colors.primary;

	        border-color: $colors.primary;

	    }

	

	    .gx-db-widget .gx-db-widget .bootstrap-switch-off

	    {

	        background-color: $colors.gray03;

	        border-color: $colors.gray03;

	    }

	    

	    .gx-db-widget .bootstrap-switch .bootstrap-switch-handle-on.bootstrap-switch-default,.gx-db-widget .bootstrap-switch .bootstrap-switch-handle-off.bootstrap-switch-default,.gx-db-widget .bootstrap-switch .bootstrap-switch-handle-off.bootstrap-switch-primary,.gx-db-widget .bootstrap-switch .bootstrap-switch-handle-on.bootstrap-switch-primary

	    {

	        background-color: transparent;

	    }

	

	    .gx-db-object-map .gx-qv-tooltip-text

	    {

	        letter-spacing: 0.38px !important;

	        line-height: 13px !important;

	        font-family: $fonts.primary-regular;

	        font-size: $fontSizes.s;

	        color: $colors.on-primary;

	    }

	

	    .gx-db-object-map .gx-qv-tooltip-box

	    {

	        height: 30px !important;

	        border-radius: 2px !important;

	        opacity: 0.9 !important;

	        background-color: $colors.gray04 !important;

	        border-color: $colors.gray04;

	    }

	    

	    .gx-db-object-map.qv-map

	    {

	        background-color: $colors.elevation-01;

	    }

	

	    .gx-db-object-map .gx-qv-title

	    {

	        color: $colors.on-background;

	        font-family: $fonts.primary-bold;

	        font-size: $fontSizes.s;

	    }

	     

	    .gx-db-object-map .gx-qv-legend-text

	    {

	        color: $colors.on-background;

	        font-family: $fonts.primary-regular;

	        font-size: $fontSizes.s;

	    }

	    

	}</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="36982745-cb77-47a3-bc04-9d0d764ff532"><Source></Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml></InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</Name><Value>DashboardViewerWeb</Value></Property><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Object><Object parentGuid="634922c3-27ba-4d2f-8e8f-91ce48da70b2" user="GeneXus" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2023-07-26T16:44:31.0000000Z" checksum="a34136e5030224c5343c08d80d1868cf" fullyQualifiedName="GeneXusReporting.QueryViewerWeb" moduleGuid="8d6bd4ab-a1a0-422d-a589-fb9e0cd18539" guid="dc2e3894-0c1f-4667-8f79-4b455513ae00" name="QueryViewerWeb" type="78b3fa0e-174c-4b2b-8716-718167a428b5" description="Query Viewer Web" parent="GeneXusReporting.Unanimo" parentType="00000000-0000-0000-0000-000000000008"><Part type="75e52d99-6edd-4bad-a1d7-dcc9b7f000ef"><Source>tokens QueryViewer (color-scheme:dark|[light])

	{

	    

	    ##colors

	    {

	        gxqv-color-main: $colors.primary;

	    }

	

	    @color-scheme = light {

	        ##colors

	        {

	        gxqv-color-01: #182f53;

	        gxqv-color-02: #a7e9e1;

	        gxqv-color-03: #f57a4d;

	        gxqv-color-04: #fbbc58;

	        gxqv-color-05: #9c3725;

	        gxqv-color-06: #2ed3c6;

	        gxqv-color-07: #aa6890;

	        gxqv-color-08: #c53b3d;

	        gxqv-color-09: #8d89a3;

	        gxqv-color-10: #095d6a;

	           

	        }

	    }

	    

	    @color-scheme = dark {

	        ##colors

	        { 

	        gxqv-color-01: #345a8c;

	        gxqv-color-02: #dcf6f4;

	        gxqv-color-03: #f8af96;

	        gxqv-color-04: #fde2b6;

	        gxqv-color-05: #da553b;

	        gxqv-color-06: #96e4dc;

	        gxqv-color-07: #c490af;

	        gxqv-color-08: #d8777b;

	        gxqv-color-09: #b9b7c8;

	        gxqv-color-10: #2eb7de;

	    

	        }

	    }

	

	}

	</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="c6b14574-4f5f-4e35-aaa7-e322e88a9a10"><Source>styles QueryViewer {   

	

	    @import GeneXusUnanimo.UnanimoWeb;

	

	    .QueryViewer

		{

	        //Output colors

			gx-qv-chart-color-first: $colors.gxqv-color-01;

			gx-qv-chart-color-second: $colors.gxqv-color-02;

			gx-qv-chart-color-third: $colors.gxqv-color-03;

			gx-qv-chart-color-fourth: $colors.gxqv-color-04;

			gx-qv-chart-color-fifth: $colors.gxqv-color-05;

			gx-qv-chart-color-sixth: $colors.gxqv-color-06;

			gx-qv-chart-color-seventh: $colors.gxqv-color-07;

			gx-qv-chart-color-eighth: $colors.gxqv-color-08;

			gx-qv-chart-color-nineth: $colors.gxqv-color-09;

			gx-qv-chart-color-tenth: $colors.gxqv-color-10;

	        gx-qv-chart-background-color: $colors.elevation-01;

	        gx-qv-map-background-color: $colors.elevation-01;

	        gx-qv-card-sparkline-color: $colors.gxqv-color-01;

	        gx-qv-pivot-table-footer-background-color:  $colors.elevation-01;

	        gx-qv-pivot-table-dialog-color: $colors.on-background;

	        gx-qv-pivot-table-header-background-color: $colors.elevation-01;

	        gx-qv-pivot-table-dialog-title-background-color: $colors.elevation-01;

	        gx-qv-table-dialog-title-background-color: $colors.elevation-01;

	        gx-qv-table-footer-background-color:  $colors.elevation-01;

	        gx-qv-table-header-background-color: $colors.elevation-01;

	        

	        //Border style

	        gx-qv-chart-background-border-color: $colors.gray01;

	       

	        //Fonts style

	        gx-qv-chart-series-labels-font-size: $fontSizes.s;

	        gx-qv-pivot-table-axes-title-font-size: $fontSizes.s;

	        gx-qv-pivot-table-data-title-font-size: $fontSizes.s;

	        gx-qv-chart-series-labels-font-family: $fonts.primary-regular;

	        gx-qv-chart-series-labels-color: $colors.on-background;

	        gx-qv-pivot-table-axes-total-font-family: $fonts.primary-bold;

	        gx-qv-pivot-table-data-title-font-family: $fonts.primary-bold;

	        gx-qv-pivot-table-axes-title-font-family: $fonts.primary-bold;

	        gx-qv-pivot-table-header-font-family: $fonts.primary-bold;

	        gx-qv-table-column-headers-font-size: $fontSizes.s;

	        gx-qv-table-column-headers-font-family: $fonts.primary-bold;

	        gx-qv-map-series-labels-color: $colors.on-background;

	        gx-qv-map-series-labels-font-family: $fonts.primary-regular;

	        gx-qv-map-series-labels-font-size: $fontSizes.s;

	        

	        //Axes style

	        gx-qv-chart-axes-line-color: $colors.gray01;

	        gx-qv-chart-axes-title-font-family: $fonts.primary-regular;

	        gx-qv-chart-axes-title-font-size: $fontSizes.s;

	        gx-qv-chart-axes-title-color: $colors.gray03;

	        gx-qv-chart-axes-labels-color: $colors.gray03;

	        gx-qv-chart-axes-labels-font-family:$fonts.primary-regular;

	        gx-qv-chart-axes-labels-font-size: $fontSizes.s;

	

	        //Title style

	        gx-qv-chart-title-font-family: $fonts.primary-bold;

	        gx-qv-chart-title-font-size: $fontSizes.s;

	        gx-qv-chart-title-font-weight: bold;

	        gx-qv-chart-title-color: $colors.on-background;

	        gx-qv-map-title-color: $colors.on-background;

	        gx-qv-map-title-font-family: $fonts.primary-bold;

	        gx-qv-map-title-font-size: $fontSizes.s;

	        gx-qv-pivot-table-title-font-family: $fonts.primary-bold;

	        gx-qv-pivot-table-title-font-size: $fontSizes.s;

	        gx-qv-pivot-table-title-color: $colors.on-background;

	        gx-qv-table-title-font-family: $fonts.primary-bold;

	        gx-qv-table-title-font-size: $fontSizes.s;

	        gx-qv-table-title-color: $colors.on-background;

	        

	        //Legend style

	        gx-qv-chart-legend-font-size: $fontSizes.xs;

	        gx-qv-chart-legend-color: $colors.on-background;

	        gx-qv-chart-legend-font-family: $fonts.primary-regular;

	        gx-qv-chart-legend-font-weight: normal;

	        gx-qv-map-legend-color: $colors.on-background;

	        gx-qv-map-legend-font-family: $fonts.primary-regular;

	        gx-qv-map-legend-font-size: $fontSizes.s;

	

	        //Tooltip style

	        gx-qv-chart-tooltip-background-color: $colors.gray04;

	        gx-qv-chart-tooltip-border-color: $colors.gray04;

	        gx-qv-chart-tooltip-font-family: $fonts.primary-bold;

	        gx-qv-chart-tooltip-font-size: $fontSizes.s;

	        gx-qv-chart-tooltip-color: $colors.on-primary;

	        gx-qv-map-tooltip-background-color: $colors.gray04 !important;

	        gx-qv-map-tooltip-border-color: $colors.gray04 !important;

	        gx-qv-map-tooltip-font-family: $fonts.primary-regular !important;

	        gx-qv-map-tooltip-font-size: $fontSizes.s !important;

	        gx-qv-map-tooltip-color: $colors.on-primary;

	    }

	

	    .highcharts-grid-line

	    {

	        color: $colors.gray01;

	    }

	

	    .highcharts-title

	    { 

	        fill: $colors.on-background;

	    }

	

	    .qv-chart .highcharts-root text, .qv-chart .QVTimelineHeaderContainer, .qv-chart .QVTimelineHeaderContainer a, .qv-chart .QVTimelineHeaderContainer select

	    {

	        font-family: $fonts.primary-regular; 

	        font-size: $fontSizes.s; 

	    }

	

	    .highcharts-container

	    {

	        font-family: $fonts.primary-regular; 

	        font-size: $fontSizes.s; 

	    }

	

	    ##region table

	        

	        .QueryViewer-table .material-icons, .QueryViewer-table  .div_buttons_popup .btn:not(:hover) {

	            color: $colors.gxqv-color-main;

	        }

	        

	        .QueryViewer-table .div_buttons_popup .btn {

	            border-color: $colors.gxqv-color-main;

	        }

	        

	        .QueryViewer-table .div_buttons_popup .btn:hover {

	            background: $colors.gxqv-color-main;

	        }

	

	        .oatgrid_top_div, .oatgrid

	        {

	            font-family: $fonts.primary-regular; 

	            font-size: $fontSizes.s;

	        }

	

	        .oatgrid_top_div

	        {

	            @include heading-04;

	            border: 0px solid;

	            border-bottom: $borders.extra-small solid $colors.gray01;

	            float: left;

	            text-transform: none !important;

	            height: 48px;

	            padding-left: $spacing.inline-xl;

	            padding-right: $spacing.inline-xl;

	            line-height: 34px;

	            background: $colors.elevation-01; 

	            border-top-right-radius: $radius.xl;

	            border-top-left-radius: $radius.l;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01;

	            border-color: $colors.gray01;

	            overflow: inherit;

	        }

	

	        .exportOptionsAnchor

	        {

	            float: inherit;

	            position: absolute;

	            display: inline;

	            inset-inline-end: 32px;

	        }

	

	        .table-sort-image table-sort-none &gt; .material-icons

	        {

	            color: $colors.on-primary;

	        }

	

	        .exportOptionsAnchor .material-icons

	        {

	            font-size: 20px;

	            padding-top: $spacing.stack-xs;

	        }

	

	        .pivot_pag_div &gt; span &gt; span

	        {

	            display: inline-block;

	        }

	

	        .table-sort-image

	        {

	            bottom: 0px;

	        }

	

	        .oatgrid .header_value

	        {

	            background-color: $colors.elevation-01;

	            text-align: start;

	            padding-inline-start: $spacing.inline-xl;

	            color: $colors.on-background;

	            font-size: $fontSizes.s;

	            font-family: $fonts.primary-bold;

	        }

	

	        ##pivot_pag_div &gt; span

	        {

	            float: right;

	            margin-top: $spacing.stack-s;

	        }

	

	

	        .oatgrid .row_value

	        {

	            padding: $spacing.inset-xs;

	            padding-inline-start: $spacing.inline-xl;

	            padding-inline-end: $spacing.inline-xl;

	        }

	    

	        .oat_winrect_container .btn, .oat_winrect_container_small .btn

	        {

	            font-weight: 600;

	        } 

	

	        .oat_winrect_close_b &gt; .material-icons

	        {

	            color: $colors.on-background !important;

	            font-size: $fontSizes.m;

	            margin-bottom: $spacing.stack-s;

	            display: inline;

	        }

	

	        .oat_winrect_close_b 

	        {

	            position: absolute;

	            display: inline;

	            inset-inline-end: 10px;

	            float: unset;

	        }

	

	        .search_input

	        {

	            font-family: $fonts.primary-regular;

	            text-indent: $spacing.inline-xl;

	            height: 30px;

	            border-color: $colors.on-background;

	            margin-top: 8px !important;

	            margin-bottom: $spacing.stack-xs;

	            background: $colors.elevation-02;

	            color: $colors.on-background;

	            text-shadow: none;

	            position: relative;        

	        }

	        

	        .oat_winrect_content_small .search_input

	        {

	            width:revert;

	        }

	

	        .oatfilterwindow &gt; .last_div_popup &gt; .div_filter_input &gt; .material-icons , .oatpop-up &gt; .last_div_popup &gt; .div_filter_input &gt; .material-icons

	        {

	            position: relative;

	            color: $colors.on-background !important;

	            z-index: 1;    

	            top: 27px;

	            padding-inline-end: 8px;

	            padding-inline-start: 8px;

	        }

	

	        .oatpop-up &gt; div:nth-child(2)

	        {

	            padding-inline-start: $spacing.inline-l !important;

	        }

	

	        .div_filter_input

	        {

	            text-align: start;

	        }

	

	        .oatfilterwindow &gt; .last_div_popup

	        {

	            padding-top: 5px;

	            margin-top: 0px;

	        }

	

	        .span_txt_pivot

	        {

	            margin-left: $spacing.inline-m;

	        }

	  

	        .gx-db-object-table

	        {

	            background-color: $colors.elevation-01;

	            border-radius: $radius.xl;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01;

	            border-bottom: 0px;

	        }

	

	        .divIeContainer

	        {

	            display: contents;

	        }

	

	        .oatgrid_top_div::before, .oatgrid .even td::before

	        {

	            background: transparent;

	            content: none;

	        }

	

	        .header_value &gt; .material-icons

	        { 

	            padding-left: $spacing.inline-m;

	            padding-right: $spacing.inline-m;

	            visibility: hidden;

	        }

	

	        .header_value:hover &gt; .div_settings &gt; .material-icons

	        {

	            visibility: visible; 

	        }

	

	        .move_item_img

	        {

	            margin-bottom: 0px;

	            padding-top: $spacing.stack-s;

	        }

	

	        .oatfilterwindow &gt; div:nth-child(2)

	        {

	            border-top: $borders.extra-small solid $colors.gray01;

	        }

	

	        .oatfilterwindow &gt; div

	        {

	            margin-left: 0px;

	            margin-right: 0px;

	            margin-bottom: 0px;

	        }

	

	        .oatgrid thead td

	        {

	            background-color: $colors.elevation-01;

	        }

	

	        .oatgrid .odd, .oatgrid .even

	        {

	            background: $colors.elevation-01;

	        }

	

	        .oatgrid td

	        {

	            border-bottom: $borders.extra-small solid $colors.gray01;

	            border-inline-start: $borders.extra-small solid $colors.gray01;

	            border-inline-end: 0px solid;

	            color: $colors.on-background;

	        }

	

	        .oatgrid &gt; tbody &gt; tr &gt; td:nth-child(1)

	        {

	            border-left: 0px solid;

	            border-right: 0px solid;

	        }

	

	        .oatgrid td:nth-child(1)

	        {

	            border-left: 0px solid;

	            border-right: 0px solid;

	        }

	

	        .material-icons

	        {

	            font-size: 16px;

	        }

	

	        .oat_winrect_container hr

	        {

	            border-top: $borders.extra-small solid $colors.gray01;

	            border-bottom: $borders.extra-small solid $colors.gray01;

	            border-bottom-width: 1px;

	            border-top-width: 0px;

	            margin-bottom: 0px;

	        }

	

	        ##pop-up &gt; .last_div_popup

	        {

	            margin-top: 5px;

	            border-bottom-width: 0px;

	        }

	

	        .oat_winrect_container

	        {

	            border-radius: $radius.xl;

	            box-shadow: $shadows.s;

		        border: 0px solid;

	            background-color: $colors.elevation-02;

	            font-family: $fonts.primary-regular;

	            font-size: $fontSizes.s;

	            margin-bottom: 0px;

	            color: $colors.on-background;

	        }

	

	        .oat_winrect_container &gt; label

	        {

	            display: inline;

	        }

	

	        .oat_winrect_title

	        {    

	            text-align: inherit;

	            color: $colors.on-background;

	            font-family: $fonts.primary-semibold;

	            padding-inline-end: $spacing.inline-l;

	            padding-inline-start: $spacing.inline-xl;

	            font-size: $fontSizes.s;

	            border-bottom: $borders.extra-small solid $colors.gray01;

	            border-color:  $colors.gray01;

	            border-top-left-radius: $radius.xl;

	            border-top-right-radius: $radius.xl;

	            margin-bottom: 0px;

	            background-color: $colors.elevation-02;

	        }

	

	        .div_label_win &gt; span

	        {

	            letter-spacing: $spacing.letter-spacing-xs;

	        }

	

	        .table-sort-asc i , .table-sort-desc i

	        {

	            line-height: $spacing.line-height-xs;

	        }

	

	    ##endregion

	

	    ##region pivot_table

	

	        .QueryViewer-pivottable .material-icons, .QueryViewer-pivottable  .div_buttons_popup .btn:not(:hover) {

	            color: $colors.gxqv-color-main;

	        }

	        .QueryViewer-pivottable .div_buttons_popup .btn, .QueryViewer-pivottable  .pivot_filter_div &gt; span:first-child {

	            border-color: $colors.gxqv-color-main;

	        }

	        .QueryViewer-pivottable .h2subtitle, .QueryViewer-pivottable  .gtotal {

	            border-bottom-color: $colors.gxqv-color-main;

	        }

	        .QueryViewer-pivottable .div_buttons_popup .btn:hover {

	            background: $colors.gxqv-color-main;

	        }

	

	        .gx-db-object-pivottable

	        {

	            background-color: $colors.elevation-01;

	            border-radius: $radius.xl;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01;

	        }

	

	        .pivot_filter_div::before, .grandtotaltitle::before, .h2subtitle::before, .gtotal::before, .grandtotalvalue::before, .firstlevelvalue::before, .subtitleFirstLevel::before

	        {

	            background-color: transparent;

	            content: none;

	        }

	

	        .pivot_pag_div

	        {

	            padding-left: 0px;

	            padding-right: 0px;

	            border-left: 0px solid;

	            border-bottom: 0px solid;

	            border-right: 0px solid;

	            border-bottom-left-radius: $radius.xl;

	            border-bottom-right-radius: $radius.xl;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01 !important;

	            border-top: 0px solid !important;

	            background: $colors.elevation-01;

	            overflow: inherit;

	            height: 52px;

	            text-align: start;

	        }

	

	        .disabled_pivot_button

	        {

	            pointer-events: none;

	            opacity: 0.4;

	        }

	

	        .check_item_img, .check_item_img_small, .uncheck_item_img, .uncheck_item_img_small

	        {

	            padding-bottom: $spacing.stack-s;

	            padding-top: $spacing.stack-s;

	            margin-bottom: 0px;

	        }

	

	        .check_item_img:hover, .check_item_img_small:hover, .uncheck_item_img:hover, .uncheck_item_img_small:hover , .export_item_div:hover

	        {

	            background-color: $colors.elevation-01;

	        }

	

	        .check_item_img i, .check_item_img_small i, .uncheck_item_img i, .uncheck_item_img_small i, .first_popup_subdiv i

	        {

	            margin-right: 0px;

	        }

	

	        .check_item_img &gt; label &gt; span , .check_item_img_small &gt; label &gt; span, .uncheck_item_img &gt; label  &gt; span, .uncheck_item_img_small &gt; label &gt; span, .first_popup_subdiv &gt; label &gt; span

	        {

	            margin-inline-start: $spacing.inline-l;

	        }

	

	        .div_buttons_popup

	        {

	            margin-bottom: $spacing.stack-m;

	            margin-top: $spacing.stack-m;

	            margin-left: 15px !important;

	            text-align: center;

	            display: contents;

	        }

	

	        .div_buttons_popup .btn

	        {

	            border-radius: $radius.m;

	            font-family: $fonts.primary-semibold;

	            font-size: $fontSizes.s;

	            text-transform: uppercase;

	            min-width: 58px;

	            background-color: $colors.elevation-02;            

	        }

	

	        .div_buttons_popup .btn:hover, .div_buttons_popup .btn:focus

	        {

	            color: $colors.on-primary;

	        }

	

	        .winrect_title_label

	        {

	            color: $colors.on-background;

	            font-family: $fonts.primary-bold;

	        }

	

	        .pivot_table tr

	        {

	            border-radius: 0px;

	        }

	

	        .grandtotalvalue

	        {

	            background-color: $colors.elevation-01;

	            font-weight: none;

	        }

	

	        .firstlevelvalue

	        {

	            font-weight: none;

	        }

	

	        .h2title

	        {

	            color: $colors.on-alert;

	            background-color: $colors.elevation-01;

	            font-size: $fontSizes.s;

	            font-family: $fonts.primary-bold;

	            text-align: start;

		        font-weight: none;

	            padding: 0px 16px 0px 16px !important;

	        }

	

	        .h2titlewhite

	        {

	            color: $colors.on-alert;

	            background-color: $colors.elevation-01;

	            font-size: $fontSizes.s;

	            font-family: $fonts.primary-bold;

	            text-align: start;

		        font-weight: none;

	            padding: 0px 16px 0px 16px !important;

	        }

	

	        .h2subtitle

	        {

	            font-size: $fontSizes.s;

	            text-align: left;

	            padding-left: $spacing.inline-xl;

	            background: revert;

	            background-color: $colors.elevation-01;

	            font-family: $fonts.primary-regular;

	        }

	

	        .grandtotaltitle

	        {

	            text-align: start;

	            padding-left: $spacing.inline-xl;

	        }

	

	        .subtitleFirstLevel

	        {

	            text-align: left;

	            padding-left: $spacing.inline-xl;

	        }

	

	        .inner_filter_div &gt; span

	        {

	            color: $colors.on-background;

	            font-family: $fonts.primary-semibold;

	            font-size: $fontSizes.s;

	        }

	

	        .inner_filter_div

	        {

	            float: initial;

	            display: inline;

	            margin-right: 0px;

	        }

	

	        .close_span_filter i

	        {

	            font-size: $fontSizes.l;

	            color: $colors.on-background !important;

	            padding-left: $spacing.inline-xs;

	        }

	

	        .pivot_table th.even .expanded, .pivot_table td.even .expanded, .pivot_table th.even .collapsed, .pivot_table td.even .collapsed

	        {

	            display: initial;

	            margin-inline-start: 0px !important;

	        }

	

	        .oatgrid tr

	        {

	            border-left: 0px solid;

	            border-right: 0px solid;

	        }

	

	        .oatgrid

	        {

	            border-radius: $radius.xl;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01;

	            border-top: 0px !important;

	            border-color: $colors.gray01;

	            overflow: inherit;

	        }

	

	        .pivot_title_div

	        {

	            height: 48px;

	            text-align: start;

	            line-height: 38px;

	            height: 48px;

	            font-size: $fontSizes.s;

	            font-family: $fonts.primary-bold;

	            padding-inline-start: $spacing.inline-xl;

	            padding-inline-end: $spacing.inline-xl;

	            background-color: $colors.elevation-01;

	            border-top-left-radius: $radius.xl;

	            border-top-right-radius: $radius.xl;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01 !important;

	            border-bottom: 0px solid !important;

	            overflow: hidden !important;

	            color: $colors.on-background;

	        }

	

	        .h2title, .h2titlewhite

	        {

	            border-bottom-width: $borders.extra-small !important;

	            border-bottom-color: $colors.gray01;

	        }

	

	        .pivot_pag_div .pagefirst, .pivot_pag_div .pagelast, .pivot_pag_div .pagenext, .pivot_pag_div .pageprev

	        {

	            display: inline-block;

	            cursor: pointer;

	            width: 22px;

	            height: 22px;

	        }

	

	        .QueryViewer-pivottable .pivot_table th.h2title, .QueryViewer-pivottable .pivot_table th.h2titlewhite, .QueryViewer-pivottable .oat_winrect_title

	        {

	            padding-inline-start: $spacing.inline-xl;

	            font-family: $fonts.primary-bold;

	            font-size: $fontSizes.s;

	            color: $colors.on-background;

	            letter-spacing: 0.25px;

	        }

	

	        .QueryViewer-pivottable .pivot_table th.h2subtitle

	        {

	            padding-left: $spacing.inline-xl;

	        }

	

	        .sort-asc, .sort-desc , .table-sort-image

	        {

	            right: revert !important;

	            display: inline;

	            inset-inline-end: 10px  !important;

	        }

	

	        .sort-asc &gt; .material-icons

	        {

	            font-size: $fontSizes.m;

	            visibility: visible !important;

	        }

	

	        .pivot_table th.h2subtitle, .pivot_table td.gtotal

	        {

		        border-bottom-width: $borders.extra-small;

	        }

	

	        .pivot_table td.gtotal.firstlevelvalue, .pivot_table td.gtotal.grandtotalvalue, .pivot_table th.h2subtitle.grandtotaltitle, .pivot_table th.h2subtitle.subtitleFirstLevel

	        {

		        border-bottom-width: $borders.small;

	        }

	

	        .pivot_pag_div span:nth-child(2)

	        {

	            color: $colors.gray02;

	            font-family: $fonts.primary-regular;

	            font-size: $fontSizes.s;

	            height: 16px;

	            top: 4px;

	            letter-spacing: $spacing.letter-spacing-xs;

	            position: absolute;

	            display: inline;

	            inset-inline-end: 10px;

	            direction: inherit;

	        }

	

	        .filterInfoUser &gt; .material-icons:hover

	        {

	            color: $colors.gray02 !important;

	            cursor: pointer;

	        }

	

	        .div_filter_search

	        {

	            display: inline-block;

	        }

	

	        .div_filter_search &gt; .material-icons

	        {

	            position: absolute;

	            left: 19px;

	            bottom: 154px;

	            color: $colors.on-background;

	            font-size: $fontSizes.m;

	        }

	

	        .drag_drop_indicator &gt; .material-icons

	        {

	            color: $colors.gray02;

	        }

	

	        .pivot_filter_div, .pivot_table

	        { 

	            font-family: $fonts.primary-regular; 

	            font-size: $fontSizes.s; 

	        }

	

	        .h2title &gt; div &gt; div:nth-child(1) &gt; .material-icons

	        {

	            visibility: hidden;

	        }

	

	        .h2title:hover &gt; div &gt; div &gt; .div_settings &gt; .material-icons

	        {

	            visibility: visible;  

	        }

	

	        .h2title &gt; div

	        {

	            display: inline;

	        }

	

	        .oat_winrect_content &gt; div &gt; div

	        {

	            padding-inline-start: $spacing.inline-xl;

	            padding-inline-end: $spacing.inline-xl;

	            padding-top: 4px;

	            padding-bottom: 4px;

	        }

	

	        .div_label_win

	        {

	            padding-inline-end: $spacing.inline-xl;

	            padding-bottom: $spacing.stack-s;

	            margin-bottom: 0px;

	            padding-top: $spacing.stack-s;

	            margin-top: 0px;

	        }

	

	        .down_container

	        {

	            margin-left: 0px; 

	            margin-right: 0px;

	        }

	        .export_item_div

	        {

	            margin-bottom: 0px;

	        }

	

	        .export_item_div &gt; .pivot_checkbox_restoreview

	        {

	            padding-left: 0px !important;

	        }

	

	        .download_file_img, .download_file_img_small

	        {

	            padding-top: 0px;

	            padding-bottom: $spacing.stack-m;

	            margin-right: 0px;

	            margin-inline-end: $spacing.inline-l;

	        }

	

	        ##pop-up &gt; div

	        {

	            margin-left: 0px;

	            margin-right: 0px;

	            margin-bottom: 0px;

	        }

	

	        .upper_container

	        {

	            margin: 0px;

	            margin-top: $spacing.stack-s;

	            margin-bottom: $spacing.stack-s;

	        }

	       

	        .div_buttons_popup &gt; button:first-child

	        {

	            border-start-end-radius: 0px;

	            border-end-end-radius: 0px;

	        }

	

	        .div_buttons_popup &gt; button:nth-child(2)

	        {

	            border-start: 0px;

	            border-start-start-radius: 0px;

	            border-end-start-radius: 0px;

	            border-start-end-radius: 0px;

	            border-end-end-radius: 0px;

	            border-end: 0px;

	        }

	

	        .div_buttons_popup &gt; button:nth-child(3)

	        {

	            border-start-start-radius: 0px;

	            border-end-start-radius: 0px;

	            margin-inline-end: $spacing.inline-xl;

	        }

	

	        .pivot_filter_div{

	            border: 0px solid;

	            padding-top: $spacing.stack-s !important;

	            padding-left: $spacing.inline-xl !important;

	            padding-right: $spacing.inline-xl !important;

	            height: 37px;

	            background: $colors.elevation-01;

	            margin-bottom: 0px;

	            padding-bottom: 0px;

	            padding-top: 0px;

	            border-top-left-radius: $radius.s;

	            border-top-right-radius: $radius.s;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01 !important;

	            border-bottom: 0px !important;

	            background-color: $colors.elevation-01;

	            overflow: hidden !important;

	        }

	

	        .pivot_table &gt; tbody

	        {

	            border-bottom-left-radius: $radius.xl;

	            border-bottom-right-radius: $radius.xl;

	            box-shadow: $shadows.xxs;

	            border: $borders.extra-small solid $colors.gray01 !important;

	            border-top: 0px !important;

	            border-color: $colors.gray01;

	            background-color: $colors.elevation-01;

	            overflow: hidden;

	        }

	        

	        .pivot_filter_div &gt; span:first-child

	        {

	            float: unset;

	            border-style: dotted;

	            border-radius: $radius.xs;

	            border-width: $borders.extra-small;

	            padding: $spacing.inset-xs;

	            padding-left: $spacing.inline-xl;

	            padding-right: $spacing.inline-xl;

	            color: $colors.on-background;

	        }

	

	        .pivot_table th, .pivot_table td

	        {

	            padding-inline-start: $spacing.inline-xl;

	            padding-inline-end: $spacing.inline-xl;

	            height: 30px;

	            border-width: 0px;

	            color: $colors.on-background;

	        }

	

	        .pivot_table th.even, .pivot_table td.even 

	        {

	            border-bottom-width: $borders.extra-small;

	            border-bottom-color: $colors.gray01;

	        }

	

	        .gtotal

	        {

	            border-top-width: 0px !important;

	            border-left-width: 0px !important;

	            border-right-width: 0px !important;

	            background: revert;

	            background-color: $colors.elevation-01;

	        }

	

	        .subtotal

	        {

	            background-color: $colors.elevation-01;

	            border-bottom-width: $borders.extra-small !important;

	            border-bottom-color: $colors.gray01;            

	        }

	

	        .inner_filter_div &gt; select

	        {

	            border-radius: $radius.l;

	            border: $borders.extra-small solid $colors.gray03;

	            appearance: none;

	            font-size: $fontSizes.s;

	            background-position: right;

	            background-size:  $fontSizes.s;

	            background-repeat: no-repeat;

	            min-width: 120px;

	            max-width: 180px;

	            margin-inline-start: 10px;

	            height: 32px;

	            padding-inline-end: $spacing.inline-xl !important;

	            box-shadow: none !important;

	            background-image: gx-image(GeneXusReporting.arrow_double);

	        }

	        body[dir="rtl"] .inner_filter_div &gt; select

	        {

	            background-position-x: left;

	        }

	

	        .pivot_table th.even .expanded i, .pivot_table td.even .expanded i, .pivot_table th.even .collapsed i, .pivot_table td.even .collapsed i

	        {

	            font-size: $fontSizes.m;

	            opacity: 1;

	            padding-inline-start: $spacing.inline-xl;

	        }

	

	        .gx_usercontrol qv-chart QueryViewer-chart

	        {

	            margin: $spacing.inset-s;

	            margin-bottom: $spacing.stack-m;

	            margin-right: $spacing.inline-l;

	            margin-left: $spacing.inline-l;

	        }

	

	        .ExportPopup

	        {

	            min-width: 168px;

	            background-color: $colors.elevation-02;

	        }

	

	        ##tablePagination_perPage

	        {

	            display: flex;

	            order: 1;

	            line-height: 36px;  

	            font-family: $fonts.primary-regular;

	            padding-inline-start: $spacing.inline-xl;

	            font-size: $fontSizes.s;

	            color: $colors.gray02;

	        }

	

	        .pivot_pag_div &gt; span &gt; span &gt; div

	        {

	            display: inline-block;

	        }

	

	        ##tablePagination_perPage &gt; select

	        {

	            margin-inline-start: 4px;

	            display: flex;

	            order: 2;

	            border-radius: $radius.xl;

	            border-color: $colors.border-gray-03;

	            color: $colors.on-background;

	            background-color: $colors.elevation-01;

	            height: 26px;

	            width: 42px !important;

	            font-size: $fontSizes.xs;

	            font-family: $fonts.primary-regular;

	            margin-top: $spacing.stack-s;

	            line-height: 20px;   

	        }

	

	        .pagelast .material-icons , .pagenext .material-icons , .pagefirst .material-icons ,.pageprev .material-icons

	        {

	            color: $colors.gxqv-color-main;

	        }

	

	        .sort-desc &gt; .material-icons

	        {

	            font-size: $fontSizes.m;

	        }

	

	        ##tablePagination_currPage

	        {

	            border-radius: $radius.xl;

	            border: $borders.extra-small solid $colors.border-gray-03;

	            height: 26px;

	            width: 39px;

	            text-align: center;

	            margin-top: $spacing.stack-s;

	            color: $colors.on-background;

	            background-color: $colors.elevation-01;

	            font-family: $fonts.primary-regular;

	            font-size: $fontSizes.s;

	        }

	

	        .spanHoverLabel

	        {

	            color: $colors.on-primary;

	            font-family: $fonts.primary-regular;

	            font-size: $fontSizes.s;

	            text-align: left;

	            padding: $spacing.inline-l;

	            padding-right: $spacing.inline-m;

	            position: absolute;

	            z-index: 1;

	            width: 300px;

	            background: $colors.gray04;

	            border-color: $colors.gray04;

	            border-radius: $radius.s;

	            opacity: 0.9;

	        }

	

	        .drag_drop_indicator

	        {

	            position: absolute;

	            top: -2px;

	            left: 0px;

	            float: left;

	            display: inline-block;

	        }

	

	        .filterInfoUser

	        {

	            display: inline-block;

	            width: 18px;

	            height: 23px;

	            margin-inline-start: $spacing.inline-xs;

	            margin-top: $spacing.stack-xs;

	        }

	

	        .filterInfoUser .spanHoverLabel

	        {

	            visibility: hidden;

	            position: absolute;

	            z-index: 1;

	            opacity: 0;

	        }

	

	        .filterInfoUser:hover .spanHoverLabel

	        {

	            visibility: visible;

	            opacity: 1;

	        }

	

	        .drag_drop_arrow

	        {

	            position: absolute;

	            top: -2px;

	            right: 0px;

	            float: right;

	            display: inline-block;

	        }

	

	        .gx-qv-selected-element 

	        {

		        background: rgba(105, 110, 242, 0.2);

	        }

	

	    ##endregion

	

	    ##region chart

	

	        .QVTimelineHeaderGroup

	        {

	            color: $colors.on-background;

	        }

	

	        .QVTimelineHeaderGroup &gt; div &gt; span 

	        {

	            opacity: 1 !important;

	        }

	

	        .QVTimelineHeaderGroup input[type="checkbox"] 

	        {

	            -webkit-appearance: revert;     // reverts UnanimoWeb setting

	            appearance: revert;             // reverts UnanimoWeb setting

	            width: 16px;

	            height: 16px;

	        }

	

	        .QVTimelineHeaderGroup input[type="checkbox"]:after 

	        {

	            background-color: revert;       // reverts UnanimoWeb setting

	        }

	

	        .QVTimelineHeaderGroup input[type="checkbox"]:disabled:after  

	        {

	            background-color: $colors.on-disabled;

	        }

	

	        .gx-qv-chart-title

	        {

	            text-align: left;

	        }

	        

	        .highcharts-legend-item path.highcharts-graph

	        {

	            display: none;

	        }

	

	        .highcharts-legend-item path.highcharts-point

	        {

	            d : path("M 2 5 L 14 5 L 14 17 L 2 17 Z");

	        }

	

	        .highcharts-point

	        {

	            rx:0;

	            ry:0;

	        }

	

	        .highcharts-series:not(.highcharts-pie-series) .highcharts-point-select, .highcharts-markers .highcharts-point-select

	        {

	            fill: rgba(105, 110, 242, 0.5);

	            stroke: rgba(105, 110, 242, 0.5);

	        }

	

	        .att_drag_drop

	        {

	            background-color: $colors.elevation-01;

	            border-radius: $radius.s;

	            cursor: grabbing;

	            box-shadow: $shadows.xxs;

	            height: 30px;

	            color: $colors.on-alert;

	            font-family: $fonts.primary-bold;

	            font-size: $fontSizes.s;

	            line-height: 30px;

	            padding-inline-end: $spacing.inline-xl;

	            padding-inline-start: $spacing.inline-xl;

	        }

	

	        .drag_drop_indicator

	        {

	            padding-inline-start: 0px;

	            float: right;

	        }

	

	        .div_settings

	        {

	            display: inline-block;

	            padding-inline-start: $spacing.inline-m !important;

	            position: absolute;

	        }

	

	        .div_settings &gt; .material-icons

	        {

	            visibility: hidden;

	            padding-bottom: $spacing.stack-xs;

	        }

	

	        .div_filter_input &gt; .material-icons

	        {

	            display: table;

	        }

	

	        body[dir="rtl"] .pagenext

	        {

	            transform: rotate(180deg);

	        }

	

	        body[dir="rtl"] .pagelast 

	        {

	            transform: rotate(180deg);

	        }

	

	        body[dir="rtl"] .pagefirst

	        {

	            transform: rotate(180deg);

	        }

	

	        body[dir="rtl"] .pageprev

	        {

	            transform: rotate(180deg);

	        }

	

	    ##endregion

	

	    ##region map

	        

	        .QueryViewer-map .gx-qv-tooltip-text

	        {

	            letter-spacing: 0.38px !important;

	            line-height: 13px !important;

	        }

	 

	        .QueryViewer-map .gx-qv-tooltip-box

	        {

	            height: 30px !important;

	            border-radius: 2px !important;

	            opacity: 0.9 !important;

	        }

	       

	        .QueryViewer-map .gx-qv-selected-element 

	        {

		        background: rgba(105, 110, 242, 0.4);

	        }

	

	    ##endregion

	

	    ##region Card

	

	        .qv-card

	        {

	            font-family: $fonts.primary-regular; 

	            font-size: $fontSizes.s;

	            color: $colors.on-background;

	        }

	

	        .qv-card i

	        {

	            color: $colors.gxqv-color-main;

	        }

	        

	        .qv-card-element-value

	        {

	            color: $colors.gray02;

	            font-family:  $fonts.primary-semibold;

	            font-size: 80px;

	            font-weight: 600;

	            height: 100px;

	            letter-spacing: 0px;

	            text-align: center;

	            width: 168px;

	        }

	

	        .qv-card-element-title

	        {

	            color:  $colors.on-background;

	            font-family:  $fonts.primary-bold;

	            font-size: $fontSizes.s;

	            font-weight: bold;

	            height: 13px;

	            letter-spacing: 0.38px;

	            line-height: 13px;

	            text-align: center;

	            width: 119px;

	        }

	

	

	    ##endregion

	

	}</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="36982745-cb77-47a3-bc04-9d0d764ff532"><Source></Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml></InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</Name><Value>QueryViewerWeb</Value></Property><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Object><Object parentGuid="634922c3-27ba-4d2f-8e8f-91ce48da70b2" user="GeneXus" versionDate="0001-01-01T00:00:00.0000000" lastUpdate="2024-05-16T00:33:15.0000000Z" checksum="7efd04c1b714fa19c45099e161374627" fullyQualifiedName="GeneXusReporting.QueryViewer" moduleGuid="8d6bd4ab-a1a0-422d-a589-fb9e0cd18539" guid="bccf72fd-d791-413c-bfac-b9ab94df7d9e" name="QueryViewer" type="78b3fa0e-174c-4b2b-8716-718167a428b5" description="Query Viewer" parent="GeneXusReporting.Unanimo" parentType="00000000-0000-0000-0000-000000000008"><Part type="75e52d99-6edd-4bad-a1d7-dcc9b7f000ef"><Source>tokens QueryViewer (color-scheme:dark|[light]) {

	    @color-scheme = light {

	        ##colors {

	            gxqv-color-01: #182f53;

	            gxqv-color-02: #a7e9e1;

	            gxqv-color-03: #f57a4d;

	            gxqv-color-04: #fbbc58;

	            gxqv-color-05: #9c3725;

	            gxqv-color-06: #2ed3c6;

	            gxqv-color-07: #aa6890;

	            gxqv-color-08: #c53b3d;

	            gxqv-color-09: #8d89a3;

	            gxqv-color-10: #095d6a;

	        }

	    }

	    

	    @color-scheme = dark {

	        ##colors { 

	            gxqv-color-01: #345a8c;

	            gxqv-color-02: #dcf6f4;

	            gxqv-color-03: #f8af96;

	            gxqv-color-04: #fde2b6;

	            gxqv-color-05: #da553b;

	            gxqv-color-06: #96e4dc;

	            gxqv-color-07: #c490af;

	            gxqv-color-08: #d8777b;

	            gxqv-color-09: #b9b7c8;

	            gxqv-color-10: #2eb7de;

	        }

	    }

	}

	</Source><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="c6b14574-4f5f-4e35-aaa7-e322e88a9a10"><Source>styles QueryViewer {

	    @import GeneXusUnanimo.Unanimo.tokens;

	    

	    .QueryViewer {

	        background-color: $colors.surface;

	        color: $colors.surface-negative;

	

	        // Card

	        gx-qv-card-element-title-class: gx-query-viewer-card__title;

	        gx-qv-card-element-value-class: gx-query-viewer-card__value;

	        gx-qv-card-max-min-title-class: gx-query-viewer-card__max-min-title;

	        gx-qv-card-max-min-value-class: gx-query-viewer-card__max-min-value;

	        gx-qv-card-sparkline-color: $colors.gxqv-color-01;

	

	        // Pivot

	        --gx-query-viewer-pivot__cell-padding-inline: 8px;

	        --gx-query-viewer-pivot__cell-padding-block: 5px;

	        --gx-query-viewer-pivot__icon-color: $colors.primary;

	        --gx-query-viewer-pivot__border-color: $colors.border-gray-01;

	    }

	

	    .QueryViewer, 

	    ##pop-up,

	    .oat_winrect_container {

	        font-size: $fontSizes.s;

	        line-height: 18px;

	        letter-spacing: $spacing.letter-spacing-xs;

	    }

	

	

	    ##region card

	        .gx-query-viewer-card__value {

	            color: $colors.gray02;

	            font-family: $fonts.primary-semibold;

	            font-size: 80px;

	            height: 100px;

	        }

	

	        .gx-query-viewer-card__title {

	            color: $colors.on-background;

	            font-family: $fonts.primary-bold;

	            font-size: $fontSizes.s;

	            letter-spacing: .38px;

	            line-height: 13px;

	        }

	

	        gx-query-viewer-card::part(trend) {

	            color: $colors.primary;

	        }

	

	        .gx-query-viewer-card__max-min-title{

	

	        }

	

	        .gx-query-viewer-card__max-min-value{

	

	        }

	    ##endregion

	

	    ##region pivot

	        .pivot_table,

	        .oatgrid {

	            font-size: $fontSizes.s;

	            line-height: 18px; 

	            letter-spacing: $spacing.letter-spacing-xs;

	        }

	

	        .close_span_filter &gt; .material-icons,

	        .exportOptionsAnchor &gt; .material-icons,

	        .sort-asc &gt; .material-icons,

	        .sort-desc &gt; .material-icons,

	        .table-sort-asc &gt; .material-icons,

	        .table-sort-desc &gt; .material-icons,

	        .pivot_pag_div .pagefirst &gt; .material-icons,

	        .pivot_pag_div .pagelast &gt; .material-icons,

	        .pivot_pag_div .pagenext &gt; .material-icons,

	        .pivot_pag_div .pageprev &gt; .material-icons,

	        .div_settings &gt; .material-icons,

	        .filterInfoUser &gt; .material-icons,

	        .oat_winrect_close_b &gt; .material-icons,

	        .drag_drop_indicator &gt; .material-icons {

	            inline-size: 24px;

	            block-size: 24px;

	            -webkit-mask-repeat: no-repeat;

	            -webkit-mask-position: center;

	            -webkit-mask-size: 100%;

	            background-color: currentColor;

	        }

	

	        

	

	        .inner_filter_div .close_span_filter &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.close_ico);

	            inline-size: 22px;

	            block-size: 22px;

	            // color: var(--text-un-text__on-surface--positive);

	        }

	

	        .exportOptionsAnchor{

	            transform: scaleX(1.25);

	        }

	

	        .exportOptionsAnchor &gt; .material-icons{

	            -webkit-mask-image: gx-image(GeneXusUnanimo.list_view);

	            -webkit-mask-size: 80%;

	        }

	

	        .sort-asc &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_asc);

	        }

	

	        .sort-desc &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_desc);

	        }

	

	        .table-sort-asc &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_asc);

	        }

	

	        .table-sort-desc &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_desc);

	        }

	

	        .pivot_pag_div .pagefirst &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_first);

	            inline-size: 16px;

	            block-size: 16px;

	        }

	

	        .pivot_pag_div .pagelast &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_last);

	            inline-size: 16px;

	            block-size: 16px;

	        }

	

	        .pivot_pag_div .pagenext &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_right);

	            inline-size: 16px;

	            block-size: 16px;

	        }

	

	        .pivot_pag_div .pageprev &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.arrow_left);

	            inline-size: 16px;

	            block-size: 16px;

	        }

	

	        .div_settings &gt; .material-icons{

	            -webkit-mask-image: gx-image(GeneXusUnanimo.settings);

	        }

	

	        .pivot_filter_div .filterInfoUser &gt; .spanHoverLabel {

	            font-family: $fonts.primary-regular;

	            color: $colors.on-primary;

	            text-align: start;

	            padding: $spacing.stack-m;

	            background-color: $colors.border-gray-04;

	            border-color: $colors.border-gray-04;

	            border-radius: $radius.l;

	            opacity: 1;

	        }

	

	        .pivot_filter_div .filterInfoUser &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.info);

	            inline-size: 18px;

	            block-size: 18px;

	        }

	

	        .oat_winrect_title {

	            margin-inline: -8px;

	            border-block-end: 1px solid $colors.border-gray-01;

	            padding-inline: 5px;

	            padding-block-end: 8px;

	        }

	

	        .oat_winrect_title .oat_winrect_close_b &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.close_ico);

	            inline-size: 18px;

	            block-size: 18px;

	        }

	

	        .drag_drop_indicator &gt; .material-icons {

	            -webkit-mask-image: gx-image(GeneXusUnanimo.grid_view); // drag icon missing

	            -webkit-mask-size: 80%;

	            inline-size: 18px;

	            block-size: 18px;

	            margin-bottom: 6px;

	        }

	

	        

	

	        

	

	        .oat_winrect_container {

	            border-radius: $radius.l;

	            padding: $spacing.stack-m;

	        }

	

	        .pivot_title_div {

	            border: 1px solid $colors.border-gray-02;

	            border-start-start-radius: $radius.l;

	            border-start-end-radius: $radius.l;

	        }

	

	        .pivot_table :is(td.gtotal.firstlevelvalue,

	        td.gtotal.grandtotalvalue,

	        th.h2subtitle.grandtotaltitle,

	        th.h2subtitle.subtitleFirstLevel) {

	            border-block-end: 2px solid $colors.primary;

	        }

	

	        .pivot_table :is(th.even, td.even) :is(.expanded, .collapsed) {

	            margin-inline: $spacing.stack-s;

	        }

	

	        .grandtotaltitle,

	        .grandtotalvalue {

	            text-transform: uppercase;

	        }

	

	        .pivot_title_div,

	        .pivot_pag_div,

	        .oatgrid_top_div,

	        .gx-query-viewer-pivot-container &gt; span {

	            padding-block: 14px;

	            padding-inline: 8px;

	        }

	        

	        .gx-query-viewer-pivot-container &gt; span, .oatgrid_top_div{

	            border-start-end-radius: 6px;

	            border-start-start-radius: 6px;

	        }

	         .pivot_title_div, .pivot_pag_div{

	            border-end-start-radius: 6px;

	            border-end-end-radius: 6px;

	        }

	

	        .oatgrid_top_div &gt; span {

	            display: flex;

	            align-items: center;

	        }

	

	        .oatfilterwindow &gt; .first_popup_subdiv{

	            padding: 8px;

	            border-bottom: 1px solid $colors.border-gray-01;

	            margin-inline: -8px;

	        }

	

	        .move_item_img{

	            margin-block: 4px;

	        }

	

	        .pivot_filter_div &gt; span:first-child {

	            border: $borders.extra-small dotted $colors.primary;

	            padding: $spacing.stack-s;

	        }

	

	        .check_item_img i,

	        .check_item_img_small i,

	        .uncheck_item_img i,

	        .uncheck_item_img_small i {

	            color: $colors.primary;

	            position: relative;

	            padding-block: 4px;

	            top: 2px;

	        }

	

	        .first_popup_subdiv i {

	            color: $colors.primary;

	            position: relative;

	            top: 3px;

	        }

	

	        .down_container{

	            gap: 4px;

	        }

	

	        .oatfilterwindow &gt; .first_popup_subdiv &gt; .first_div_label &gt; span {

	            padding-inline: 8px;

	        }

	

	        .div_buttons_popup .btn {

	            border-radius: unset;

	            color: $colors.primary;

	            font-family: $fonts.primary-semibold;

	        }

	

	        .oatfilterwindow &gt; hr {

	            margin: 8px;

	            width: unset;

	        }

	

	        .div_buttons_popup .btn:nth-child(1) {

	            border-start-start-radius: $radius.l;

	            border-end-start-radius: $radius.l;

	        }

	

	        .div_buttons_popup .btn:nth-child(2) {

	            border-inline: unset;

	        }

	

	        .div_buttons_popup .btn:nth-child(3) {

	            border-start-end-radius: $radius.l;

	            border-end-end-radius: $radius.l;

	        }

	

	        .div_buttons_popup .btn:hover {

	            background-color: $colors.primary;

	            border-color: $colors.primary;

	            color: $colors.alt-surface;

	        }

	

	        ##pop-up hr,

	        .oat_winrect_container hr {

	            margin-inline: -8px;

	            border: 0.5px solid $colors.border-gray-01;

	        }

	

	        .oat_winrect_container &gt; .oat_winrect_title {

	            padding-inline-start: $spacing.stack-m;

	        }

	

	        .pivot_pag_div input {

	            position: relative;

	            border-radius: $radius.l;

	            border: 1px solid $colors.border-gray-04;

	            font-size: $fontSizes.s;

	            line-height: 18px; 

	            letter-spacing: $spacing.letter-spacing-xs;

	            block-size: 24px;

	        }

	

	        .inner_filter_div &gt; select {

	            position: relative;

	            border-radius: $radius.l;

	            border: 1px solid $colors.border-gray-04;

	            // color: var(--body-texts-un-body-m__font-color--positive);

	            font-size: $fontSizes.s;

	            line-height: 18px; 

	            letter-spacing: $spacing.letter-spacing-xs;

	            block-size: 24px;

	            padding: 5px;

	            block-size: 32px;

	            max-block-size: 32px;

	        }

	

	        ##tablePagination_perPage &gt; select {

	            padding-inline: 4px;

	            block-size: 24px;

	            position: relative;

	            border-radius: $radius.l;

	            border: 1px solid $colors.border-gray-04;

	            // color: var(--body-texts-un-body-m__font-color--positive);

	            font-size: $fontSizes.s;

	            line-height: 18px; 

	            letter-spacing: $spacing.letter-spacing-xs;

	        }

	

	        .div_filter_input &gt; .search_input {

	            background-image: gx-image(GeneXusUnanimo.search);

	            background-repeat: no-repeat;

	            background-position: 4px;

	            background-size: 20px;

	            position: relative;

	            block-size: 32px;

	            max-block-size: 32px;

	            padding-inline: 28px 8px;

	            border-radius: $radius.l;

	            border: 1px solid $colors.border-gray-04;

	            font-size: $fontSizes.s;

	            line-height: 18px; 

	            letter-spacing: $spacing.letter-spacing-xs;

	        }

	

	        .h2title,

	        .h2titlewhite,

	        .h2subtitle .grandtotaltitle,

	        .winrect_title_label,

	        .h2subtitle.subtitleFirstLevel,

	        .QueryViewer-pivottable .pivot_table th.h2subtitle,

	        .pivot_filter_div,

	        .pivot_title_div,

	        .grandtotaltitle,

	        .grandtotalvalue,

	        .gtotal.firstlevelvalue,

	        .header_value &gt; span,

	        .oatgrid_top_div &gt; span,

	        .gx-query-viewer-pivot-container &gt; span {

	            font-family: $fonts.primary-semibold;

	            font-size: $fontSizes.s;

	            line-height: 18px;

	            letter-spacing: $spacing.letter-spacing-m;

	        }

	

	        .pivot_pag_div span:nth-child(2),

	        ##tablePagination_perPage {

	            font-size: $fontSizes.xs;

	            line-height: 13px; 

	            letter-spacing: $spacing.letter-spacing-xs;

	        }

	        

	    ##endregion

	}

