><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>beaconProximityAlertsCollection</Value></Property></Properties></ExternalMethod><ExternalMethod><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>proximityAlertRegionId</Value></Property><Property><Name>ExoItemDesc</Name><Value>The beacon proximity alert region's identifier to stop monitoring.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:VarChar</Value></Property><Property><Name>ExoItemLength</Name><Value>256</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>RemoveBeaconProximityAlert</Value></Property><Property><Name>ExoItemDesc</Name><Value>Removes the beacon region being monitored.</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>removeBeaconProximityAlertWithParameters</Value></Property></Properties></ExternalMethod><ExternalMethod><Properties><Property><Name>IntName</Name><Value>ClearBeaconProximityAlerts</Value></Property><Property><Name>ExoItemDesc</Name><Value>Removes all the beacon regions being monitored.</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>clearBeaconProximityAlerts</Value></Property></Properties></ExternalMethod><ExternalMethod><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>regionId</Value></Property><Property><Name>ExoItemDesc</Name><Value>The beacon region's identifier to retrieve state.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:VarChar</Value></Property><Property><Name>ExoItemLength</Name><Value>256</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>GetBeaconRegionState</Value></Property><Property><Name>ExoItemDesc</Name><Value>Retrieve the cached state of the specified region.</Value></Property><Property><Name>ExoItemBasedOn</Name><Value>Domain:RegionState, GeneXus</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>beaconRegionStateWithParameters</Value></Property></Properties></ExternalMethod><ExternalMethod><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>beaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>The region object that defines the identifying information for the targeted beacons.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconRegion, GeneXus.SD</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>StartRangingBeaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>Starts the delivery of notifications for beacons in the specified region.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:Boolean</Value></Property><Property><Name>ExoItemLength</Name><Value>4</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>startRangingBeaconRegionWithParameters</Value></Property></Properties></ExternalMethod><ExternalMethod><Properties><Property><Name>IntName</Name><Value>GetRangedBeaconRegions</Value></Property><Property><Name>ExoItemDesc</Name><Value>Retrieve a collection for the beacon regions that are currently providing ranging.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconRegion, GeneXus.SD</Value></Property><Property><Name>ExoItemIsCollection</Name><Value>True</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>rangedBeaconRegionsCollection</Value></Property></Properties></ExternalMethod><ExternalMethod><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>regionId</Value></Property><Property><Name>ExoItemDesc</Name><Value>The beacon region's identifier.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:VarChar</Value></Property><Property><Name>ExoItemLength</Name><Value>256</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>StopRangingBeaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>Stops the delivery of notifications for the specified beacon region.</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>stopRangingBeaconRegionWithParameters</Value></Property></Properties></ExternalMethod><ExternalMethod><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>regionId</Value></Property><Property><Name>ExoItemDesc</Name><Value>The beacon region's identifier to retrieve becons in range. Empty means all regions.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:VarChar</Value></Property><Property><Name>ExoItemLength</Name><Value>256</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>GetBeaconsInRange</Value></Property><Property><Name>ExoItemDesc</Name><Value>Retrieve a collection for the beacons (sorted by proximity) currently in range for the given region.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconState, GeneXus.SD</Value></Property><Property><Name>ExoItemIsCollection</Name><Value>True</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>beaconsInRangeWithParameters</Value></Property></Properties></ExternalMethod><ExternalMethod><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>beaconInfo</Value></Property><Property><Name>ExoItemDesc</Name><Value>The beacon information to advertice.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconInfo, GeneXus.SD</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>StartAsBeacon</Value></Property><Property><Name>ExoItemDesc</Name><Value>Advertises the current device as a beacon.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:Boolean</Value></Property><Property><Name>ExoItemLength</Name><Value>4</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>startAsBeaconWithParameters</Value></Property></Properties></ExternalMethod><ExternalMethod><Properties><Property><Name>IntName</Name><Value>StopAsBeacon</Value></Property><Property><Name>ExoItemDesc</Name><Value>Stops advertising the current device as a beacon.</Value></Property><Property><Name>ExoItemType</Name><Value>bas:Boolean</Value></Property><Property><Name>ExoItemLength</Name><Value>4</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property><Property><Name>ExoNameIOS</Name><Value>stopAsBeacon</Value></Property></Properties></ExternalMethod></ExternalMethods><ExternalEvents><ExternalEvent><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>beaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>An object containing information about the region that was entered.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconRegion, GeneXus.SD</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>EnterBeaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>Invoked when the user enters a monitored beacon region.</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property></Properties></ExternalEvent><ExternalEvent><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>beaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>An object containing information about the beacon region that was exited.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconRegion, GeneXus.SD</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>ExitBeaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>Invoked when the user exits a monitored beacon region.</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property></Properties></ExternalEvent><ExternalEvent><Parameters><Parameter><Properties><Property><Name>IntName</Name><Value>beaconRegion</Value></Property><Property><Name>ExoItemDesc</Name><Value>The region object containing the parameters that were used to locate the beacons.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconRegion, GeneXus.SD</Value></Property></Properties></Parameter><Parameter><Properties><Property><Name>IntName</Name><Value>beacons</Value></Property><Property><Name>ExoItemDesc</Name><Value>The beacons currently in range, sorted by proximity. If beacons is empty, it may be assumed no beacons that match the specified region are nearby. Similarly if a specific beacon no longer appears in beacons, it may be assumed the beacon is no longer received by the device.</Value></Property><Property><Name>ExoItemType</Name><Value>sdt:BeaconState, GeneXus.SD</Value></Property><Property><Name>ExoItemIsCollection</Name><Value>True</Value></Property></Properties></Parameter></Parameters><Properties><Property><Name>IntName</Name><Value>ChangeBeaconsInRange</Value></Property><Property><Name>ExoItemDesc</Name><Value>Invoked when a new set of beacons' states are available in the specified region.</Value></Property><Property><Name>ExoMethodIsStatic</Name><Value>True</Value></Property></Properties></ExternalEvent></ExternalEvents><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Part type="babf62c5-0111-49e9-a1c3-cc004d90900a"><InnerHtml></InnerHtml><Properties><Property><Name>IsDefault</Name><Value>False</Value></Property></Properties></Part><Properties><Property><Name>Name</