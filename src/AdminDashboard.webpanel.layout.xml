												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblTituloDashboard" caption="Backoffice administrativo" class="admin-topbar-title" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<label name="LblTopbarTexto" caption="Entrada unica del equipo interno, con foco en padron, deuda, importaciones y cobranza." class="admin-topbar-text" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="ResumenGeneral" columns="25%;25%;25%;25%" rows="160px" width="100%">
