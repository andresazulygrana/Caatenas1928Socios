																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblPendientes" caption="Cuotas pendientes" class="admin-kpi-label" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;TotalCuotasPendientes" readonly="True" class="admin-kpi-value" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblPendientesAyuda" caption="Periodo actual" class="admin-kpi-meta" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<smart name="CardRecaudado" columns="100%" rows="18px;52px;24px" width="100%" class="admin-kpi-card">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblRecaudado" caption="Recaudado del mes" class="admin-kpi-label" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;TotalRecaudadoMes" readonly="True" class="admin-kpi-value" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblRecaudadoAyuda" caption="Cuotas acreditadas" class="admin-kpi-meta" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Left" verticalAlignment="Middle">
											<label name="LblAccesosRapidos" caption="Accesos rapidos" class="admin-section-title" />
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="AccesosRapidos" columns="33%;33%;34%" rows="220px" width="100%">
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Top">
														<smart name="CardAccesoSocios" columns="100%" rows="28px;72px;52px" width="100%" class="surface-elevated">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCardSociosTitulo" caption="Socios" class="admin-card-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblCardSociosTexto" caption="Vista operativa del padron con estado, deuda y acceso directo a la ficha individual." class="admin-card-text" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<action name="BtnAccesoSocios" onClickEvent="'Socios'" caption="Ir a socios" class="btn-primary" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Top">
														<smart name="CardAccesoCuotas" columns="100%" rows="28px;72px;52px" width="100%" class="surface-elevated">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCardCuotasTitulo" caption="Cuotas" class="admin-card-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblCardCuotasTexto" caption="Seguimiento de pendientes, vencidas y pagos acreditados del periodo actual." class="admin-card-text" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<action name="BtnAccesoCuotas" onClickEvent="'Cuotas'" caption="Ir a cuotas" class="btn-primary" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Top">
														<smart name="CardAccesoImportar" columns="100%" rows="28px;72px;52px" width="100%" class="surface-elevated">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCardImportarTitulo" caption="Importar socios" class="admin-card-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblCardImportarTexto" caption="Carga controlada de Excel con previsualizacion y confirmacion por lote." class="admin-card-text" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<action name="BtnAccesoImportar" onClickEvent="'ImportarSocios'" caption="Ir a importar" class="btn-primary" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
		<actiongroups />
	</view>
</layout>