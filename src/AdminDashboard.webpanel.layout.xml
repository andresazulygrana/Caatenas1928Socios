																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblActivos" caption="Socios activos" class="admin-kpi-label" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;TotalSociosActivos" readonly="True" class="admin-kpi-value" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblActivosAyuda" caption="Base activa del club" class="admin-kpi-meta" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<smart name="CardMorosos" columns="100%" rows="18px;52px;24px" width="100%" class="admin-kpi-card">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<label name="LblMorosos" caption="Socios morosos" class="admin-kpi-label" />
