										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="TopbarSandbox" columns="52%;48%" rows="44px;26px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblTitulo" caption="Procesar pago sandbox" class="admin-topbar-title" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<smart name="TopbarActions" columns="50%;50%" rows="44px" width="100%">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<action name="BtnProcesarTop" onClickEvent="'Procesar'" caption="Procesar payment" class="btn-topbar" />
																</cell>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<action name="BtnDiagnosticarTop" onClickEvent="'Diagnosticar'" caption="Diagnosticar" class="btn-topbar-secondary" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<label name="LblSubtitulo" caption="Pantalla interna para depuracion y conciliacion tecnica de la respuesta de Mercado Pago." class="admin-topbar-text" />
													</cell>
													<cell />
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="EntradaPago" columns="55%;45%" rows="30px;68px;28px;44px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblPayment" caption="PaymentId Mercado Pago" class="field-label" />
													</cell>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblSocio" caption="SocioId de prueba" class="field-label" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;PaymentIdPrueba" class="field" />
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<input attribute="&amp;SocioIdPrueba" class="field" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblEstadoSandbox" caption="Estado de la ejecucion" class="field-label" />
													</cell>
													<cell />
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<input attribute="&amp;EstadoTexto" readonly="True" class="message-inline" />
													</cell>
													<cell />
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="ResultadoPago" columns="100%" rows="30px;70px;64px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblUltimaCuota" caption="Ultima cuota encontrada y configuracion activa" class="field-label" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<smart name="ResumenTecnico" columns="12%;14%;12%;12%;18%;12%;10%;10%" rows="24px;28px" width="100%">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCuotaId" caption="Id" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCuotaPeriodo" caption="Periodo" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCuotaEstado" caption="Estado" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblCuotaMPEstado" caption="MP" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblConfigNombre" caption="Configuracion" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblTokenLength" caption="Token" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblConfigActiva" caption="Activa" class="field-label" />
																</cell>
																<cell />
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;CuotaIdUltima" readonly="True" class="text-caption" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;CuotaPeriodo" readonly="True" class="text-caption" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;CuotaEstado" readonly="True" class="text-caption" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;CuotaMPEstado" readonly="True" class="text-caption" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;ConfigNombre" readonly="True" class="text-caption" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;TokenLength" readonly="True" class="text-caption" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<input attribute="&amp;ConfigActiva" readonly="True" class="text-caption" />
																</cell>
																<cell />
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<smart name="RutasTecnicas" columns="50%;50%" rows="24px;40px" width="100%">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblBaseUrlTec" caption="Base URL" class="field-label" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblDebugPathTec" caption="Archivo de debug" class="field-label" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Top">
																	<input attribute="&amp;ConfigBaseUrl" readonly="True" class="helper-text" />
																</cell>
																<cell horizontalAlignment="Left" verticalAlignment="Top">
																	<input attribute="&amp;DebugFilePath" readonly="True" class="helper-text" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="DiagnosticoPago" columns="100%" rows="28px;34px;34px;34px;34px;120px;108px" width="100%" class="surface-elevated">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblDiagnostico" caption="Diagnostico tecnico del pago" class="field-label" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<input attribute="&amp;HttpStatus" readonly="True" class="text-caption" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<input attribute="&amp;ErrCode" readonly="True" class="text-caption" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<input attribute="&amp;ErrDescription" readonly="True" class="text-caption" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblJson" caption="JSON devuelto por la consulta" class="field-label" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<input attribute="&amp;JsonPago" readonly="True" class="message-inline" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<label name="LblSandboxAyuda" caption="Usa este panel para validar respuestas del proveedor y verificar el archivo de debug cuando el webhook o la consulta manual no coinciden con el estado de la cuota." class="helper-text" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="AccionesPago" columns="34%;33%;33%" rows="56px" width="100%">
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<action name="BtnProcesar" onClickEvent="'Procesar'" caption="Procesar payment" class="btn-primary" />
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<action name="BtnDiagnosticar" onClickEvent="'Diagnosticar'" caption="Diagnosticar" class="btn-secondary" />
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<action name="BtnAbrirPortal" onClickEvent="'AbrirPortal'" caption="Abrir portal" class="btn-secondary" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
