<layout type="Web">
	<view>
		<smart name="MainLayout" class="backoffice-page" width="100%" height="100%" columnsStyle="100%" rowsStyle="100%">
			<row>
				<cell hAlign="Center" vAlign="Top">
					<smart name="Shell" class="backoffice-shell" width="100%" height="100%" columnsStyle="270px;100%" rowsStyle="100%">
						<row>
							<cell class="backoffice-sidebar" vAlign="Top">
								<smart name="SidebarLayout" width="100%" columnsStyle="100%" rowsStyle="74px;98px;392px;58px">
									<row><cell vAlign="Top"><smart name="Brand" width="100%" columnsStyle="56px;100%" rowsStyle="56px"><row><cell hAlign="Center" vAlign="Middle"><label name="LblCrest" caption="A" class="backoffice-crest"/></cell><cell hAlign="Left" vAlign="Middle"><smart name="BrandText" width="100%" columnsStyle="100%" rowsStyle="30px;18px"><row><cell hAlign="Left" vAlign="Bottom"><label name="LblBrandTitle" caption="Club Atenas" class="backoffice-brand-title"/></cell></row><row><cell hAlign="Left" vAlign="Top"><label name="LblBrandMeta" caption="Backoffice de socios" class="backoffice-brand-meta"/></cell></row></smart></cell></row></smart></cell></row>
									<row><cell vAlign="Middle"><smart name="SidebarCard" class="backoffice-sidebar-card" width="100%" columnsStyle="100%" rowsStyle="18px;52px"><row><cell hAlign="Left" vAlign="Bottom"><label name="LblSidebarTitle" caption="Catalogo base" class="backoffice-sidebar-section"/></cell></row><row><cell hAlign="Left" vAlign="Middle"><label name="LblSidebarText" caption="Planes, importes y acceso al resto del backoffice desde la misma envolvente lateral." class="backoffice-sidebar-text"/></cell></row></smart></cell></row>
									<row><cell vAlign="Top"><smart name="SidebarNav" width="100%" columnsStyle="100%" rowsStyle="44px;44px;44px;44px;44px;44px;44px;44px"><row><cell><action name="BtnNavDashboard" caption="Dashboard" onClickEvent="'Dashboard'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavSocios" caption="Socios" onClickEvent="'Socios'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavImportar" caption="Importar socios" onClickEvent="'ImportarSocios'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavTipos" caption="Tipos de cuota" onClickEvent="'TiposCuota'" class="btn-sidebar-active"/></cell></row><row><cell><action name="BtnNavCuotas" caption="Cuotas" onClickEvent="'Cuotas'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavConfig" caption="Configuracion pago" onClickEvent="'ConfiguracionPago'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavPruebas" caption="Prueba de pago" onClickEvent="'PruebasPago'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavSandbox" caption="Procesar sandbox" onClickEvent="'Sandbox'" class="btn-sidebar"/></cell></row></smart></cell></row>
									<row><cell vAlign="Bottom"><label name="LblSidebarFooter" caption="Usuario: Secretaria Atenas | Admin / Operacion diaria" class="backoffice-sidebar-footer"/></cell></row>
								</smart>
							</cell>
							<cell class="backoffice-main" vAlign="Top">
								<smart name="TiposBody" class="backoffice-main-body" width="100%" columnsStyle="100%" rowsStyle="128px;560px;1px">
									<row>
										<cell hAlign="Center" vAlign="Middle">
											<smart name="TopbarTipos" class="surface-elevated" width="100%" columnsStyle="62%;38%" rowsStyle="44px;26px">
												<row>
													<cell hAlign="Left" vAlign="Middle"><label name="LblTitulo" caption="Tipos de cuota" class="admin-topbar-title"/></cell>
													<cell hAlign="Right" vAlign="Middle">
														<smart name="TopbarActions" width="100%" columnsStyle="100%" rowsStyle="44px">
															<row>
																<cell hAlign="Right" vAlign="Middle"><action name="BtnNuevoTop" caption="Nuevo tipo de cuota" onClickEvent="'Nuevo'" class="btn-topbar"/></cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Top"><label name="LblSubtituloTipos" caption="Catalogo base de planes e importes que alimenta altas, cuotas nuevas e importaciones." class="admin-topbar-text"/></cell>
													<cell/>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell hAlign="Center" vAlign="Top">
											<smart name="ListadoCard" class="surface-elevated" width="100%" columnsStyle="100%" rowsStyle="28px;500px">
												<row><cell hAlign="Left" vAlign="Bottom"><label name="LblListado" caption="Planes configurados" class="text-subtitle"/></cell></row>
												<row>
													<cell vAlign="Top">
														<smart name="GridContainer" class="grid-wrap" width="100%" columnsStyle="100%" rowsStyle="40px;460px">
															<row>
																<cell vAlign="Middle">
																	<smart name="CabeceraGrid" class="grid-head" width="100%" columnsStyle="14%;44%;18%;10%;14%" rowsStyle="40px">
																		<row>
																			<cell vAlign="Middle"><label name="LblColId" caption="ID" class="grid-col-head"/></cell>
																			<cell vAlign="Middle"><label name="LblColDescripcion" caption="Descripcion" class="grid-col-head"/></cell>
																			<cell vAlign="Middle"><label name="LblColImporte" caption="Importe" class="grid-col-head"/></cell>
																			<cell vAlign="Middle"><label name="LblColActivo" caption="Activo" class="grid-col-head"/></cell>
																			<cell hAlign="Center" vAlign="Middle"><label name="LblColAccion" caption="Accion" class="grid-col-head"/></cell>
																		</row>
																	</smart>
																</cell>
															</row>
															<row>
																<cell vAlign="Top">
																	<grid name="GridTiposCuota" class="grid-body" controlType="table">
																	<table name="GridTiposCuotaItem" width="100%" columnsStyle="14%;44%;18%;10%;14%" rowsStyle="52px">
																			<row>
																				<cell vAlign="Middle"><input attribute="TipoCuotaId" readonly="True" class="grid-col-meta"/></cell>
																				<cell vAlign="Middle"><input attribute="TipoCuotaDescripcion" readonly="True" class="grid-col-text"/></cell>
																				<cell vAlign="Middle"><input attribute="TipoCuotaImporte" readonly="True" class="grid-col-text"/></cell>
																				<cell vAlign="Middle"><input attribute="&amp;TipoCuotaActivoTexto" readonly="True" class="grid-col-meta"/></cell>
																				<cell hAlign="Center" vAlign="Middle"><action name="BtnEditar" caption="Editar" onClickEvent="'Editar'" class="btn-sm-primary"/></cell>
																			</row>
																		</table>
																	</grid>
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell class="page-footer" hAlign="Center" vAlign="Middle"><label name="LblPieTipos" caption="" class="helper-text"/></cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
		<actiongroups />
	</view>
</layout>
