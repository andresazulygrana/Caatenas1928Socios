<layout type="Web">
	<view>
		<responsive name="PageContent" class="page page-no-hero">
			<row>
				<cell>
					<responsive name="HeaderBand" class="page-header">
						<row>
							<cell hAlign="Left" vAlign="Middle">
								<table name="HeaderBrand" class="header-brand" tableType="Flex" alignItems="Center" width="100%">
									<row>
										<cell flexGrow="0" vAlign="Middle">
											<label name="LblEscudoPortal" caption="A" class="header-crest"/>
										</cell>
										<cell flexGrow="0">
											<responsive name="HeaderTextBlock">
												<row>
													<cell>
														<table name="HeaderNameRow" tableType="Flex" alignItems="Center">
															<row>
																<cell flexGrow="0"><label name="LblBrandClub" caption="Club" class="header-name"/></cell>
																<cell flexGrow="0"><label name="LblBrandAtenas" caption="Atenas" class="header-name header-name--accent"/></cell>
															</row>
														</table>
													</cell>
												</row>
												<row>
													<cell><label name="LblPortalSub" caption="Comprobante" class="header-tagline"/></cell>
												</row>
											</responsive>
										</cell>
									</row>
								</table>
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
			<row>
				<cell hAlign="Center" vAlign="Top">
					<responsive name="MainContent" class="page-content">
						<row>
							<cell>
								<responsive name="ReceiptCard" class="surface">
									<row>
										<cell>
											<smart name="ReceiptHeader" class="receipt-header" width="100%" columnsStyle="100%" rowsStyle="20px;28px;20px">
												<row><cell hAlign="Center"><label name="LblReceiptTitle" caption="Comprobante" class="receipt-header-title"/></cell></row>
												<row><cell hAlign="Center"><input attribute="&amp;ReferenciaOperacion" readonly="True" class="receipt-header-id"/></cell></row>
												<row><cell hAlign="Center"><input attribute="&amp;FechaPagoTexto" readonly="True" class="receipt-header-date"/></cell></row>
											</smart>
										</cell>
									</row>
									<row><cell><label name="LblDividerOne" caption="" class="receipt-divider"/></cell></row>
									<row>
										<cell>
											<smart name="ReceiptAmount" class="receipt-amount" width="100%" columnsStyle="100%" rowsStyle="20px;44px">
												<row><cell hAlign="Center"><label name="LblTotalAbonado" caption="Total pagado" class="receipt-amount-label"/></cell></row>
												<row><cell hAlign="Center"><input attribute="&amp;ImportePagadoTexto" readonly="True" class="receipt-amount-value"/></cell></row>
											</smart>
										</cell>
									</row>
									<row><cell><label name="LblDividerTwo" caption="" class="receipt-divider"/></cell></row>
									<row><cell><smart name="RowSocio" class="info-row" width="100%" columnsStyle="35%;65%" rowsStyle="24px"><row><cell><label name="LblSocioComp" caption="Socio" class="info-label"/></cell><cell hAlign="Right"><input attribute="&amp;NombreSocio" readonly="True" class="info-value"/></cell></row></smart></cell></row>
									<row><cell><smart name="RowCuota" class="info-row" width="100%" columnsStyle="35%;65%" rowsStyle="24px"><row><cell><label name="LblPeriodoComp" caption="Cuota" class="info-label"/></cell><cell hAlign="Right"><input attribute="&amp;PeriodoCuota" readonly="True" class="info-value"/></cell></row></smart></cell></row>
									<row><cell><smart name="RowConcepto" class="info-row" width="100%" columnsStyle="35%;65%" rowsStyle="24px"><row><cell><label name="LblTipoComp" caption="Concepto" class="info-label"/></cell><cell hAlign="Right"><input attribute="&amp;TipoCuotaNombre" readonly="True" class="info-value"/></cell></row></smart></cell></row>
									<row><cell><smart name="RowMedio" class="info-row" width="100%" columnsStyle="35%;65%" rowsStyle="24px"><row><cell><label name="LblMedioComp" caption="Medio" class="info-label"/></cell><cell hAlign="Right"><label name="LblMedioValor" caption="Mercado Pago" class="info-value"/></cell></row></smart></cell></row>
									<row><cell><smart name="RowRef" class="info-row" width="100%" columnsStyle="35%;65%" rowsStyle="24px"><row><cell><label name="LblRefComp" caption="Referencia" class="info-label"/></cell><cell hAlign="Right"><input attribute="&amp;ReferenciaOperacion" readonly="True" class="info-value"/></cell></row></smart></cell></row>
									<row><cell><label name="LblDividerThree" caption="" class="receipt-divider"/></cell></row>
									<row><cell hAlign="Center"><label name="LblAyudaComprobante" caption="clubatenas.uy &#183; Documento sin valor fiscal" class="receipt-footer"/></cell></row>
								</responsive>
							</cell>
						</row>
						<row><cell/></row>
						<row><cell><action name="BtnImprimir" caption="Imprimir / Descargar PDF" onClickEvent="'Imprimir'" class="btn-primary"/></cell></row>
						<row><cell><action name="BtnInicio" caption="Volver al inicio" onClickEvent="'IrInicio'" class="btn-secondary"/></cell></row>
						<row><cell hAlign="Center"><label name="LblFooterPortal" caption="clubatenas.uy &#183; Socios" class="page-footer"/></cell></row>
					</responsive>
				</cell>
			</row>
		</responsive>
		<actiongroups/>
	</view>
</layout>
