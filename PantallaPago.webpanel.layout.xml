<layout type="Web">
	<view>
		<responsive name="PageContent" class="page">
			<row>
				<cell>
					<responsive name="HeaderBand" class="page-header">
						<row>
							<cell hAlign="Left" vAlign="Middle">
								<table name="HeaderBrand" class="header-brand" tableType="Flex" alignItems="Center" width="100%">
									<row>
										<cell flexGrow="0" vAlign="Middle">
											<label name="LblEscudoPortal" caption="A" class="header-crest"/>
										</cell>
										<cell flexGrow="0">
											<responsive name="HeaderTextBlock">
												<row>
													<cell>
														<table name="HeaderNameRow" tableType="Flex" alignItems="Center">
															<row>
																<cell flexGrow="0"><label name="LblBrandClub" caption="Club" class="header-name"/></cell>
																<cell flexGrow="0"><label name="LblBrandAtenas" caption="Atenas" class="header-name header-name--accent"/></cell>
															</row>
														</table>
													</cell>
												</row>
												<row>
													<cell><label name="LblPortalSub" caption="Estado de cuenta" class="header-tagline"/></cell>
												</row>
											</responsive>
										</cell>
									</row>
								</table>
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
			<row>
				<cell hAlign="Center" vAlign="Top">
					<responsive name="MainContent" class="page-content">
						<row>
							<cell hAlign="Center" vAlign="Top">
								<responsive name="HeroBand" class="page-hero">
									<row><cell hAlign="Center" vAlign="Middle"><label name="LblTitulo" caption="Tu cuota" class="text-title"/></cell></row>
									<row><cell hAlign="Center" vAlign="Middle"><label name="LblSubtitulo" caption="Revis&#225; tu estado actual y pag&#225; tu membres&#237;a." class="text-subtitle"/></cell></row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="ImporteCard" class="surface">
									<row>
										<cell>
											<smart name="AmountBlock" class="amount-block" width="100%" columnsStyle="100%" rowsStyle="28px;52px">
												<row><cell hAlign="Center"><label name="LblImporteTitulo" caption="Importe a pagar" class="amount-label"/></cell></row>
												<row><cell hAlign="Center"><input attribute="&amp;ImporteTexto" readonly="True" class="text-amount"/></cell></row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="RowEstadoPago" class="info-row" width="100%" columnsStyle="40%;60%" rowsStyle="24px">
												<row>
													<cell><label name="LblEstadoPago" caption="Estado actual" class="info-label"/></cell>
													<cell hAlign="Right"><input attribute="&amp;MensajeEstado" readonly="True" class="info-value"/></cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="RowPeriodoPago" class="info-row" width="100%" columnsStyle="40%;60%" rowsStyle="24px">
												<row>
													<cell><label name="LblPeriodo" caption="Per&#237;odo / vencimiento" class="info-label"/></cell>
													<cell hAlign="Right"><input attribute="&amp;CuotaPeriodo" readonly="True" class="info-value"/></cell>
												</row>
											</smart>
										</cell>
									</row>
									<row><cell vAlign="Middle"><input attribute="&amp;ResumenCuota" readonly="True" class="field-help"/></cell></row>
								</responsive>
							</cell>
						</row>
						<row><cell/></row>
						<row>
							<cell>
								<responsive name="SocioCard" class="surface">
									<row>
										<cell>
											<smart name="RowSocio" class="info-row" width="100%" columnsStyle="40%;60%" rowsStyle="24px">
												<row>
													<cell><label name="LblSocio" caption="Socio" class="info-label"/></cell>
													<cell hAlign="Right"><input attribute="&amp;SocioNombreCompleto" readonly="True" class="info-value"/></cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="RowCedula" class="info-row" width="100%" columnsStyle="40%;60%" rowsStyle="24px">
												<row>
													<cell><label name="LblDocumento" caption="C&#233;dula" class="info-label"/></cell>
													<cell hAlign="Right"><input attribute="&amp;SocioCedula" readonly="True" class="info-value"/></cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="RowPlan" class="info-row" width="100%" columnsStyle="40%;60%" rowsStyle="24px">
												<row>
													<cell><label name="LblPlan" caption="Plan" class="info-label"/></cell>
													<cell hAlign="Right"><input attribute="&amp;TipoCuotaNombre" readonly="True" class="info-value"/></cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell>
											<smart name="RowVencimiento" class="info-row" width="100%" columnsStyle="40%;60%" rowsStyle="24px">
												<row>
													<cell><label name="LblVencimiento" caption="Vencimiento" class="info-label"/></cell>
													<cell hAlign="Right"><input attribute="&amp;VencimientoTexto" readonly="True" class="info-value"/></cell>
												</row>
											</smart>
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row><cell/></row>
						<row><cell><action name="BtnPagar" onClickEvent="'AccionPrincipal'" caption="Pagar con Mercado Pago" class="btn-primary"/></cell></row>
						<row><cell><action name="BtnCambiarDocumento" onClickEvent="'CambiarSocio'" caption="Consultar otro documento" class="btn-secondary"/></cell></row>
						<row><cell hAlign="Center"><label name="LblFooterPortal" caption="clubatenas.uy &#183; Socios" class="page-footer"/></cell></row>
					</responsive>
				</cell>
			</row>
		</responsive>
		<actiongroups/>
	</view>
</layout>
