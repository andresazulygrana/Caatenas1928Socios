<layout type="Web">
	<view>
		<smart name="MainLayout" class="backoffice-page" width="100%" height="100%" columnsStyle="100%" rowsStyle="100%">
			<row>
				<cell hAlign="Center" vAlign="Top">
					<smart name="Shell" class="backoffice-shell" width="100%" height="100%" columnsStyle="270px;100%" rowsStyle="100%">
						<row>
							<cell class="backoffice-sidebar" vAlign="Top">
								<smart name="SidebarLayout" width="100%" columnsStyle="100%" rowsStyle="74px;98px;392px;58px">
									<row><cell vAlign="Top"><smart name="Brand" width="100%" columnsStyle="56px;100%" rowsStyle="56px"><row><cell hAlign="Center" vAlign="Middle"><label name="LblCrest" caption="A" class="backoffice-crest"/></cell><cell hAlign="Left" vAlign="Middle"><smart name="BrandText" width="100%" columnsStyle="100%" rowsStyle="30px;18px"><row><cell hAlign="Left" vAlign="Bottom"><label name="LblBrandTitle" caption="Club Atenas" class="backoffice-brand-title"/></cell></row><row><cell hAlign="Left" vAlign="Top"><label name="LblBrandMeta" caption="Backoffice de socios" class="backoffice-brand-meta"/></cell></row></smart></cell></row></smart></cell></row>
									<row><cell vAlign="Middle"><smart name="SidebarCard" class="backoffice-sidebar-card" width="100%" columnsStyle="100%" rowsStyle="18px;52px"><row><cell hAlign="Left" vAlign="Bottom"><label name="LblSidebarTitle" caption="Sandbox interno" class="backoffice-sidebar-section"/></cell></row><row><cell hAlign="Left" vAlign="Middle"><label name="LblSidebarText" caption="Prepara socio de prueba y verifica el flujo del portal antes de produccion." class="backoffice-sidebar-text"/></cell></row></smart></cell></row>
									<row><cell vAlign="Top"><smart name="SidebarNav" width="100%" columnsStyle="100%" rowsStyle="44px;44px;44px;44px;44px;44px;44px;44px"><row><cell><action name="BtnNavDashboard" caption="Dashboard" onClickEvent="'Dashboard'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavSocios" caption="Socios" onClickEvent="'Socios'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavImportar" caption="Importar socios" onClickEvent="'ImportarSocios'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavTipos" caption="Tipos de cuota" onClickEvent="'TiposCuota'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavCuotas" caption="Cuotas" onClickEvent="'Cuotas'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavConfig" caption="Configuracion pago" onClickEvent="'ConfiguracionPago'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavPruebas" caption="Prueba de pago" onClickEvent="'PruebasPago'" class="btn-sidebar-active"/></cell></row><row><cell><action name="BtnNavSandbox" caption="Procesar sandbox" onClickEvent="'IrSandbox'" class="btn-sidebar"/></cell></row></smart></cell></row>
									<row><cell vAlign="Bottom"><label name="LblSidebarFooter" caption="Usuario: Secretaria Atenas | Admin / Operacion diaria" class="backoffice-sidebar-footer"/></cell></row>
								</smart>
							</cell>
							<cell class="backoffice-main" vAlign="Top">
								<smart name="PruebasBody" class="backoffice-main-body" width="100%" columnsStyle="100%" rowsStyle="128px;460px;280px">
									<row>
										<cell hAlign="Center" vAlign="Middle">
											<smart name="TopbarPruebas" class="surface-elevated" width="100%" columnsStyle="64%;36%" rowsStyle="44px;26px">
												<row>
													<cell hAlign="Left" vAlign="Middle"><label name="LblTitulo" caption="Prueba de pago sandbox" class="admin-topbar-title"/></cell>
													<cell hAlign="Right" vAlign="Middle">
														<smart name="TopbarActions" width="100%" columnsStyle="50%;50%" rowsStyle="44px">
															<row>
																<cell hAlign="Left" vAlign="Middle"><action name="BtnInicializarTop" caption="Inicializar tipos" onClickEvent="'InicializarTipos'" class="btn-topbar-secondary"/></cell>
																<cell hAlign="Right" vAlign="Middle"><action name="BtnPrepararTop" caption="Preparar socio prueba" onClickEvent="'Preparar'" class="btn-topbar"/></cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Top"><label name="LblSubtitulo" caption="Prepara un socio de prueba y valida el recorrido antes de pasar al portal publico." class="admin-topbar-text"/></cell>
													<cell/>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell hAlign="Center" vAlign="Top">
											<smart name="BloquePruebas" width="100%" columnsStyle="100%" rowsStyle="360px;36px;64px">
												<row>
													<cell class="surface-elevated" hAlign="Center" vAlign="Top">
														<smart name="FormularioPrueba" width="100%" columnsStyle="50%;50%" rowsStyle="28px;72px;28px;72px;28px;72px">
															<row>
																<cell hAlign="Left" vAlign="Bottom"><label name="LblCedula" caption="Cedula de prueba" class="field-label"/></cell>
																<cell hAlign="Left" vAlign="Bottom"><label name="LblNombre" caption="Nombre" class="field-label"/></cell>
															</row>
															<row>
																<cell hAlign="Center" vAlign="Middle"><input attribute="&amp;CedulaPrueba" class="field"/></cell>
																<cell hAlign="Center" vAlign="Middle"><input attribute="&amp;NombrePrueba" class="field"/></cell>
															</row>
															<row>
																<cell hAlign="Left" vAlign="Bottom"><label name="LblApellido" caption="Apellido" class="field-label"/></cell>
																<cell hAlign="Left" vAlign="Bottom"><label name="LblEmail" caption="Email test Mercado Pago" class="field-label"/></cell>
															</row>
															<row>
																<cell hAlign="Center" vAlign="Middle"><input attribute="&amp;ApellidoPrueba" class="field"/></cell>
																<cell hAlign="Center" vAlign="Middle"><input attribute="&amp;EmailPrueba" class="field"/></cell>
															</row>
															<row>
																<cell hAlign="Left" vAlign="Bottom"><label name="LblTelefono" caption="Telefono" class="field-label"/></cell>
																<cell hAlign="Left" vAlign="Bottom"><label name="LblTipo" caption="Tipo de cuota" class="field-label"/></cell>
															</row>
															<row>
																<cell hAlign="Center" vAlign="Middle"><input attribute="&amp;TelefonoPrueba" class="field"/></cell>
																<cell hAlign="Center" vAlign="Middle"><input attribute="&amp;TipoCuotaId" class="field"/></cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Middle"><label name="LblFormularioAyuda" caption="Usa datos de prueba consistentes y prepara primero el socio antes de abrir el portal publico." class="helper-text"/></cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Middle">
														<smart name="AccionesFormulario" width="100%" columnsStyle="50%;50%" rowsStyle="64px">
															<row>
																<cell hAlign="Left" vAlign="Middle"><action name="BtnPreparar" caption="Preparar socio prueba" onClickEvent="'Preparar'" class="btn-primary"/></cell>
																<cell hAlign="Center" vAlign="Middle"><action name="BtnAbrirPago" caption="Abrir portal de pago" onClickEvent="'AbrirPago'" class="btn-secondary"/></cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell hAlign="Center" vAlign="Middle">
											<smart name="ResultadoPrueba" class="surface-elevated" width="100%" columnsStyle="38%;62%" rowsStyle="30px;66px;30px;56px;40px">
												<row>
													<cell hAlign="Left" vAlign="Bottom"><label name="LblResultado" caption="Estado de la preparacion" class="field-label"/></cell>
													<cell hAlign="Left" vAlign="Bottom"><label name="LblChecklistPrueba" caption="Secuencia sugerida" class="field-label"/></cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Middle"><input attribute="&amp;EstadoTexto" readonly="True" class="message-inline"/></cell>
													<cell hAlign="Left" vAlign="Middle"><label name="LblChecklistTexto" caption="1. Preparar socio. 2. Abrir portal. 3. Ejecutar checkout. 4. Confirmar retorno en la pantalla publica." class="helper-text"/></cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Bottom"><label name="LblSocioPrueba" caption="Socio generado o reutilizado" class="field-label"/></cell>
													<cell/>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Middle"><input attribute="&amp;SocioIdPrueba" readonly="True" class="text-caption"/></cell>
													<cell hAlign="Right" vAlign="Middle"><smart name="AccionesResultado" width="100%" columnsStyle="50%;50%" rowsStyle="54px"><row><cell hAlign="Center" vAlign="Middle"><action name="BtnDashboard" caption="Volver al dashboard" onClickEvent="'IrDashboard'" class="btn-secondary"/></cell><cell hAlign="Center" vAlign="Middle"><action name="BtnPortalPublico" caption="Abrir portal publico" onClickEvent="'IrPortalPublico'" class="btn-secondary"/></cell></row></smart></cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Middle"><label name="LblPiePruebas" caption="Este panel es interno. El socio solo debe interactuar con BuscarSocio, PantallaPago y ConfirmacionPago." class="helper-text"/></cell>
													<cell/>
												</row>
											</smart>
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
		<actiongroups />
	</view>
</layout>
