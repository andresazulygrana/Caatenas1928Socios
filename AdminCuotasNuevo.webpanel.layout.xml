<layout type="Web">
	<view>
		<smart name="MainLayout" columns="100%" width="100%" height="100%" class="backoffice-page" rows="100%">
			<row>
				<cell horizontalAlignment="Center" verticalAlignment="Top">
					<smart name="Shell" columns="270px;100%" width="100%" height="100%" class="backoffice-shell" rows="100%">
						<row>
							<cell class="backoffice-sidebar" verticalAlignment="Top">
								<smart name="SidebarLayout" columns="100%" width="100%" rows="74dip;98dip;392dip;58dip">
									<row>
										<cell verticalAlignment="Top">
											<smart name="Brand" columns="56px;100%" width="100%" rows="56dip">
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<label name="LblCrest" caption="A" class="backoffice-crest" />
													</cell>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<smart name="BrandText" columns="100%" width="100%" rows="30dip;18dip">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Bottom">
																	<label name="LblBrandTitle" caption="Club Atenas" class="backoffice-brand-title" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Top">
																	<label name="LblBrandMeta" caption="Backoffice de socios" class="backoffice-brand-meta" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<smart name="SidebarCard" columns="100%" width="100%" class="backoffice-sidebar-card" rows="18dip;52dip">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblSidebarTitle" caption="Cobranza operativa" class="backoffice-sidebar-section" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblSidebarText" caption="Seguimiento de periodos, cobros y estados desde un shell lateral persistente." class="backoffice-sidebar-text" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Top">
											<smart name="SidebarNav" columns="100%" width="100%" rows="44dip;44dip;44dip;44dip;44dip;44dip;44dip;44dip">
												<row>
													<cell>
														<action name="BtnNavDashboard" onClickEvent="'Dashboard'" caption="Dashboard" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavSocios" onClickEvent="'Socios'" caption="Socios" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavImportar" onClickEvent="'ImportarSocios'" caption="Importar socios" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavTipos" onClickEvent="'TiposCuota'" caption="Tipos de cuota" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavCuotas" onClickEvent="'Cuotas'" caption="Cuotas" class="btn-sidebar-active" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavConfig" onClickEvent="'ConfiguracionPago'" caption="Configuracion pago" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavPruebas" onClickEvent="'PruebasPago'" caption="Prueba de pago" class="btn-sidebar" />
													</cell>
												</row>
												<row>
													<cell>
														<action name="BtnNavSandbox" onClickEvent="'Sandbox'" caption="Procesar sandbox" class="btn-sidebar" />
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Bottom">
											<label name="LblSidebarFooter" caption="Usuario: Secretaria Atenas | Admin / Operacion diaria" class="backoffice-sidebar-footer" />
										</cell>
									</row>
								</smart>
							</cell>
							<cell class="backoffice-main" verticalAlignment="Top">
								<smart name="CuotasBody" columns="100%" width="100%" class="backoffice-main-body" rows="128dip;180dip;180dip;520dip;1dip">
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="TopbarCuotas" columns="62%;38%" width="100%" class="surface-elevated" rows="44dip;26dip">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblTitulo" caption="Cuotas" class="admin-topbar-title" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<smart name="TopbarActions" columns="50%;50%" width="100%" rows="44dip">
															<row>
																<cell horizontalAlignment="Left" verticalAlignment="Middle">
																	<action name="BtnDashboardTop" onClickEvent="'Dashboard'" caption="Volver al dashboard" class="btn-topbar-secondary" />
																</cell>
																<cell horizontalAlignment="Right" verticalAlignment="Middle">
																	<action name="BtnFiltrarTop" onClickEvent="'Filtrar'" caption="Aplicar filtros" class="btn-topbar" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Top">
														<label name="LblSubtituloCuotas" caption="Vista operativa para detectar pendientes, vencidas y pagos acreditados." class="admin-topbar-text" />
													</cell>
													<cell />
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="FiltrosCard" columns="30%;22%;26%;22%" width="100%" class="surface-elevated" rows="34dip;82dip;34dip">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblPeriodo" caption="Periodo AAAA-MM" class="field-label" />
													</cell>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblEstado" caption="Estado" class="field-label" />
													</cell>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblBusqueda" caption="Socio o cedula" class="field-label" />
													</cell>
													<cell />
												</row>
												<row>
													<cell verticalAlignment="Middle">
														<input attribute="&amp;FiltroPeriodo" class="field" />
													</cell>
													<cell verticalAlignment="Middle">
														<input attribute="&amp;FiltroEstado" class="field" />
													</cell>
													<cell verticalAlignment="Middle">
														<input attribute="&amp;TextoBusqueda" class="field" />
													</cell>
													<cell horizontalAlignment="Right" verticalAlignment="Middle">
														<action name="BtnFiltrar" onClickEvent="'Filtrar'" caption="Aplicar filtros" class="btn-primary" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Middle">
														<label name="LblFiltrosAyuda" caption="El periodo vacio muestra todas las cuotas registradas." class="helper-text" />
													</cell>
													<cell />
													<cell />
													<cell />
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<smart name="Resumen" columns="50%;50%" width="100%" rows="36dip;142dip">
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Bottom">
														<label name="LblEsperado" caption="Total esperado" class="field-label" />
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Bottom">
														<label name="LblCobrado" caption="Total cobrado" class="field-label" />
													</cell>
												</row>
												<row>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<smart name="CardEsperado" columns="100%" width="96%" class="admin-kpi-card" rows="54dip;28dip">
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<input attribute="&amp;TotalEsperado" readonly="True" class="admin-kpi-value" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<label name="LblEsperadoHint" caption="Periodo filtrado" class="admin-kpi-meta" />
																</cell>
															</row>
														</smart>
													</cell>
													<cell horizontalAlignment="Center" verticalAlignment="Middle">
														<smart name="CardCobrado" columns="100%" width="96%" class="admin-kpi-card" rows="54dip;28dip">
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<input attribute="&amp;TotalCobrado" readonly="True" class="admin-kpi-value" />
																</cell>
															</row>
															<row>
																<cell horizontalAlignment="Center" verticalAlignment="Middle">
																	<label name="LblCobradoHint" caption="Cuotas pagadas" class="admin-kpi-meta" />
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Top">
											<smart name="ListadoCard" columns="100%" width="100%" class="surface-elevated" rows="28dip;480dip">
												<row>
													<cell horizontalAlignment="Left" verticalAlignment="Bottom">
														<label name="LblListado" caption="Listado de cuotas" class="text-subtitle" />
													</cell>
												</row>
												<row>
													<cell verticalAlignment="Top">
														<smart name="GridContainer" columns="100%" width="100%" class="grid-wrap" rows="40dip;440dip">
															<row>
																<cell verticalAlignment="Middle">
																	<smart name="CabeceraGrid" columns="14%;28%;14%;15%;15%;14%" width="100%" class="grid-head" rows="40dip">
																		<row>
																			<cell verticalAlignment="Middle">
																				<label name="LblColCedula" caption="Cedula" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColNombre" caption="Nombre" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColPeriodo" caption="Periodo" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColImporte" caption="Importe" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColEstado" caption="Estado" class="grid-col-head" />
																			</cell>
																			<cell verticalAlignment="Middle">
																				<label name="LblColFechaPago" caption="Fecha pago" class="grid-col-head" />
																			</cell>
																		</row>
																	</smart>
																</cell>
															</row>
															<row>
																<cell verticalAlignment="Top">
																	<grid name="GridCuotas" ControlType="SDSmartGrid" class="grid-body">
																		<table name="GridCuotasItem" columns="14%;28%;14%;15%;15%;14%" rows="48px" width="100%">
																			<row>
																				<cell verticalAlignment="Middle">
																					<input attribute="SocioCedula" readonly="True" class="grid-col-text" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="SocioNombre" readonly="True" class="grid-col-text" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="CuotaPeriodo" readonly="True" class="grid-col-meta" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="&amp;ImporteTexto" readonly="True" class="grid-col-meta" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="&amp;EstadoTexto" readonly="True" class="grid-col-meta" />
																				</cell>
																				<cell verticalAlignment="Middle">
																					<input attribute="&amp;FechaPagoTexto" readonly="True" class="grid-col-meta" />
																				</cell>
																			</row>
																		</table>
																	</grid>
																</cell>
															</row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell class="page-footer" horizontalAlignment="Center" verticalAlignment="Middle">
											<label name="LblPieCuotas" caption="" class="helper-text" />
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
		<actiongroups />
	</view>
</layout>