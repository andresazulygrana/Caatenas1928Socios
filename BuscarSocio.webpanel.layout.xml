<layout type="Web">
	<view>
		<responsive name="PageContent" class="page">
			<row>
				<cell>
					<responsive name="HeaderBand" class="page-header">
						<row>
							<cell horizontalAlignment="Left" verticalAlignment="Middle">
								<table name="HeaderBrand" width="100%" class="header-brand" tableType="Flex" alignItems="Center">
									<row>
										<cell verticalAlignment="Middle" flexGrow="0">
											<label name="LblEscudoPortal" caption="A" class="header-crest" />
										</cell>
										<cell flexGrow="0">
											<responsive name="HeaderTextBlock">
												<row>
													<cell>
														<table name="HeaderNameRow" tableType="Flex" alignItems="Center">
															<row>
																<cell flexGrow="0">
																	<label name="LblBrandClub" caption="Club" class="header-name" />
																</cell>
																<cell flexGrow="0">
																	<label name="LblBrandAtenas" caption="Atenas" class="header-name header-name--accent" />
																</cell>
															</row>
														</table>
													</cell>
												</row>
												<row>
													<cell>
														<label name="LblPortalSub" caption="Portal de socios" class="header-tagline" />
													</cell>
												</row>
											</responsive>
										</cell>
									</row>
								</table>
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
			<row>
				<cell horizontalAlignment="Center" verticalAlignment="Top">
					<responsive name="MainContent" class="page-content">
						<row>
							<cell horizontalAlignment="Center" verticalAlignment="Top">
								<responsive name="HeroBand" class="page-hero">
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<label name="LblTituloHero" caption="Tu portal de socio" class="text-title" />
										</cell>
									</row>
									<row>
										<cell horizontalAlignment="Center" verticalAlignment="Middle">
											<label name="LblSubtituloHero" caption="Ingresá tu cédula para consultar tu cuota." class="text-subtitle" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<responsive name="PortalCard" class="surface">
									<row>
										<cell verticalAlignment="Middle">
											<label name="LblCedula" caption="Cédula" class="field-label" />
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<input attribute="&amp;Cedula" class="field-input" />
										</cell>
									</row>
									<row>
										<cell verticalAlignment="Middle">
											<input attribute="&amp;MensajeError" readonly="True" class="message-inline" />
										</cell>
									</row>
								</responsive>
							</cell>
						</row>
						<row>
							<cell>
								<action name="BtnAcceder" onClickEvent="'Acceder'" caption="Acceder al portal" class="btn-primary" />
							</cell>
						</row>
						<row>
							<cell horizontalAlignment="Center">
								<label name="LblRegistro" caption="¿No sos socio?" class="text-caption" />
							</cell>
						</row>
						<row>
							<cell>
								<action name="BtnRegistrar" onClickEvent="'Registrarse'" caption="Registrarme" class="btn-secondary" />
							</cell>
						</row>
						<row>
							<cell horizontalAlignment="Center">
								<label name="LblFooterPortal" caption="clubatenas.uy · Socios" class="page-footer" />
							</cell>
						</row>
					</responsive>
				</cell>
			</row>
		</responsive>
		<actiongroups />
	</view>
</layout>