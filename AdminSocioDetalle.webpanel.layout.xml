<layout type="Web">
	<view>
		<smart name="MainLayout" class="backoffice-page" width="100%" height="100%" columnsStyle="100%" rowsStyle="100%">
			<row>
				<cell hAlign="Center" vAlign="Top">
					<smart name="Shell" class="backoffice-shell" width="100%" height="100%" columnsStyle="270px;100%" rowsStyle="100%">
						<row>
							<cell class="backoffice-sidebar" vAlign="Top">
								<smart name="SidebarLayout" width="100%" columnsStyle="100%" rowsStyle="74px;98px;392px;58px">
									<row><cell vAlign="Top"><smart name="Brand" width="100%" columnsStyle="56px;100%" rowsStyle="56px"><row><cell hAlign="Center" vAlign="Middle"><label name="LblCrest" caption="A" class="backoffice-crest"/></cell><cell hAlign="Left" vAlign="Middle"><smart name="BrandText" width="100%" columnsStyle="100%" rowsStyle="30px;18px"><row><cell hAlign="Left" vAlign="Bottom"><label name="LblBrandTitle" caption="Club Atenas" class="backoffice-brand-title"/></cell></row><row><cell hAlign="Left" vAlign="Top"><label name="LblBrandMeta" caption="Backoffice de socios" class="backoffice-brand-meta"/></cell></row></smart></cell></row></smart></cell></row>
									<row><cell vAlign="Middle"><smart name="SidebarCard" class="backoffice-sidebar-card" width="100%" columnsStyle="100%" rowsStyle="18px;52px"><row><cell hAlign="Left" vAlign="Bottom"><label name="LblSidebarTitle" caption="Ficha del socio" class="backoffice-sidebar-section"/></cell></row><row><cell hAlign="Left" vAlign="Middle"><label name="LblSidebarText" caption="Edicion rapida, historial de cuotas y acciones de periodo sin salir del contexto." class="backoffice-sidebar-text"/></cell></row></smart></cell></row>
									<row><cell vAlign="Top"><smart name="SidebarNav" width="100%" columnsStyle="100%" rowsStyle="44px;44px;44px;44px;44px;44px;44px;44px"><row><cell><action name="BtnNavDashboard" caption="Dashboard" onClickEvent="'Dashboard'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavSocios" caption="Socios" onClickEvent="'Socios'" class="btn-sidebar-active"/></cell></row><row><cell><action name="BtnNavImportar" caption="Importar socios" onClickEvent="'ImportarSocios'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavTipos" caption="Tipos de cuota" onClickEvent="'TiposCuota'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavCuotas" caption="Cuotas" onClickEvent="'Cuotas'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavConfig" caption="Configuracion pago" onClickEvent="'ConfiguracionPago'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavPruebas" caption="Prueba de pago" onClickEvent="'PruebasPago'" class="btn-sidebar"/></cell></row><row><cell><action name="BtnNavSandbox" caption="Procesar sandbox" onClickEvent="'Sandbox'" class="btn-sidebar"/></cell></row></smart></cell></row>
									<row><cell vAlign="Bottom"><label name="LblSidebarFooter" caption="Usuario: Secretaria Atenas | Admin / Operacion diaria" class="backoffice-sidebar-footer"/></cell></row>
								</smart>
							</cell>
							<cell class="backoffice-main" vAlign="Top">
								<smart name="DetalleBody" class="backoffice-main-body" width="100%" columnsStyle="100%" rowsStyle="128px;520px;28px;320px">
									<row>
										<cell hAlign="Center" vAlign="Middle">
											<smart name="TopbarDetalle" class="surface-elevated" width="100%" columnsStyle="62%;38%" rowsStyle="44px;26px">
												<row>
													<cell hAlign="Left" vAlign="Middle"><label name="LblTitulo" caption="Detalle de socio" class="admin-topbar-title"/></cell>
													<cell hAlign="Right" vAlign="Middle">
														<smart name="TopbarActions" width="100%" columnsStyle="50%;50%" rowsStyle="44px">
															<row>
																<cell hAlign="Left" vAlign="Middle"><action name="BtnVolver" caption="Volver a socios" onClickEvent="'Volver'" class="btn-secondary"/></cell>
																<cell hAlign="Right" vAlign="Middle"><action name="BtnGuardarTop" caption="Guardar cambios" onClickEvent="'Guardar'" class="btn-primary"/></cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell hAlign="Left" vAlign="Top"><label name="LblDetalleSubtitulo" caption="Edicion puntual, resumen financiero y acciones claras para operar sobre el socio." class="admin-topbar-text"/></cell>
													<cell/>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell hAlign="Center" vAlign="Top">
											<smart name="BloquesDatos" width="100%" columnsStyle="50%;50%" rowsStyle="520px">
												<row>
													<cell vAlign="Top">
														<smart name="DatosPersonales" class="surface-elevated" width="100%" columnsStyle="100%" rowsStyle="24px;24px;46px;24px;46px;24px;46px;24px;46px;24px;46px">
															<row><cell hAlign="Left" vAlign="Middle"><label name="LblDatosPersonalesTitle" caption="Datos personales" class="admin-card-title"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblCedula" caption="Cedula" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;Cedula" readonly="True" class="field"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblNombre" caption="Nombre" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;Nombre" class="field"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblApellido" caption="Apellido" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;Apellido" class="field"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblEmail" caption="Email" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;Email" class="field"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblTelefono" caption="Telefono" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;Telefono" class="field"/></cell></row>
														</smart>
													</cell>
													<cell vAlign="Top">
														<smart name="EstadoAcciones" class="surface-elevated" width="100%" columnsStyle="100%" rowsStyle="24px;24px;46px;24px;46px;24px;24px;40px;46px;46px">
															<row><cell hAlign="Left" vAlign="Middle"><label name="LblEstadoAccTitle" caption="Resumen y acciones" class="admin-card-title"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblEstado" caption="Estado (A activo, M moroso, I inactivo)" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;Estado" class="field"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblTipoCuota" caption="Tipo de cuota" class="field-label"/></cell></row>
															<row><cell vAlign="Middle"><input attribute="&amp;TipoCuotaId" class="field"/></cell></row>
															<row><cell hAlign="Left" vAlign="Bottom"><label name="LblTipoCuotaNombre" caption="Descripcion actual del plan" class="field-label"/></cell></row>
															<row><cell hAlign="Left" vAlign="Middle"><input attribute="&amp;TipoCuotaNombre" readonly="True" class="helper-text"/></cell></row>
															<row><cell hAlign="Left" vAlign="Middle"><input attribute="&amp;Mensaje" readonly="True" class="helper-text"/></cell></row>
															<row><cell hAlign="Left" vAlign="Middle"><action name="BtnGuardar" caption="Guardar cambios" onClickEvent="'Guardar'" class="btn-primary"/></cell></row>
															<row><cell hAlign="Left" vAlign="Middle"><action name="BtnGenerarCuota" caption="Generar cuota" onClickEvent="'GenerarCuota'" class="btn-secondary"/></cell></row>
														</smart>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
									<row>
										<cell hAlign="Left" vAlign="Middle"><label name="LblHistorial" caption="Historial de cuotas" class="admin-section-title"/></cell>
									</row>
									<row>
										<cell hAlign="Center" vAlign="Top">
											<smart name="CuotasContainer" class="grid-wrap" width="100%" columnsStyle="100%" rowsStyle="40px;280px">
												<row>
													<cell vAlign="Middle">
														<smart name="CabeceraCuotas" class="grid-head" width="100%" columnsStyle="20%;17%;14%;24%;25%" rowsStyle="40px">
															<row>
																<cell vAlign="Middle"><label name="LblCuotaPeriodo" caption="Periodo" class="grid-col-head"/></cell>
																<cell vAlign="Middle"><label name="LblCuotaImporte" caption="Importe" class="grid-col-head"/></cell>
																<cell vAlign="Middle"><label name="LblCuotaEstado" caption="Estado" class="grid-col-head"/></cell>
																<cell vAlign="Middle"><label name="LblCuotaVenc" caption="Vencimiento" class="grid-col-head"/></cell>
																<cell vAlign="Middle"><label name="LblCuotaPago" caption="Fecha de pago" class="grid-col-head"/></cell>
															</row>
														</smart>
													</cell>
												</row>
												<row>
													<cell vAlign="Top">
														<grid name="GridCuotas" class="grid-body" controlType="table">
															<table name="GridCuotasItem" width="100%" columnsStyle="20%;17%;14%;24%;25%" rowsStyle="48px">
																<row>
																	<cell vAlign="Middle"><input attribute="CuotaPeriodo" readonly="True" class="grid-col-text"/></cell>
																	<cell vAlign="Middle"><input attribute="CuotaImporte" readonly="True" class="grid-col-text"/></cell>
																	<cell vAlign="Middle"><input attribute="CuotaEstado" readonly="True" class="grid-col-meta"/></cell>
																	<cell vAlign="Middle"><input attribute="CuotaFechaVencimiento" readonly="True" class="grid-col-meta"/></cell>
																	<cell vAlign="Middle"><input attribute="CuotaFechaPago" readonly="True" class="grid-col-meta"/></cell>
																</row>
															</table>
														</grid>
													</cell>
												</row>
											</smart>
										</cell>
									</row>
								</smart>
							</cell>
						</row>
					</smart>
				</cell>
			</row>
		</smart>
		<actiongroups />
	</view>
</layout>
